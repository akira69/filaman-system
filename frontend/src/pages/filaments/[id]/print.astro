---
import Layout from '../../../layouts/Layout.astro'
import '../../../styles/print-label.css'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}
---

<Layout title="FilaMan - Print Filament Label">
  <div class="print-page">
    <aside class="print-sidebar">
      <a id="btn-back" href="#" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="label-back">Back to Filament</span>
      </a>

      <div id="load-error" style="display:none; padding: 10px 14px; background: var(--error-bg, #fee2e2); color: var(--error-text, #991b1b); border-radius: var(--radius-sm); font-size: 0.875rem;" role="alert"></div>

      <div class="settings-section">
        <h3 id="title-settings">Print Settings</h3>

        <div>
          <label class="fm-label" id="label-width-text">Width (mm)</label>
          <input type="number" id="input-width" value="60" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-height-text">Height (mm)</label>
          <input type="number" id="input-height" value="25" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-font-size-text">Font Size (%)</label>
          <input type="range" id="input-font-size" min="50" max="200" value="100" class="fm-input" style="padding: 8px;">
        </div>

        <div>
          <label class="fm-label" id="label-qr-size-text">QR Size (mm)</label>
          <input type="number" id="input-qr-size" value="22" class="fm-input">
        </div>

        <h3 id="title-display">Display</h3>
        <div class="checkbox-grid">
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-qr" checked>
            <span id="label-show-qr">QR Code</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-id" checked>
            <span id="label-show-id">Filament ID</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mfr" checked>
            <span id="label-show-mfr">Manufacturer</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mat" checked>
            <span id="label-show-mat">Material</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color" checked>
            <span id="label-show-color">Color</span>
          </label>
        </div>
      </div>

      <div class="action-buttons">
        <button id="btn-print" class="fm-btn fm-btn-primary" onclick="filamanPrint()">Print</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline">Reset</button>
      </div>
    </aside>

    <main class="preview-container">
      <div id="label-preview" class="label-preview">
        <div id="label-qr-container"></div>
        <div id="label-text-container" style="display: flex; flex-direction: column; justify-content: center; min-width: 0; line-height: 1.1;">
          <div id="prev-id" style="font-size: 1.4em; font-weight: 700; margin-bottom: 2px;"></div>
          <div id="prev-filament" style="font-size: 0.9em; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
          <div id="prev-mfr" style="font-size: 0.8em; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
          <div id="prev-color" style="font-size: 0.8em; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  ;(window as any).filamanPrint = function() {
    window.print()
  }

  const id = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]
  let labelData = {
    id,
    designation: '',
    manufacturer: '',
    type: '',
    color: '',
  }

  const widthInput = document.getElementById('input-width') as HTMLInputElement
  const heightInput = document.getElementById('input-height') as HTMLInputElement
  const fontSizeInput = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput = document.getElementById('input-qr-size') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const labelPreview = document.getElementById('label-preview') as HTMLDivElement
  const qrContainer = document.getElementById('label-qr-container') as HTMLDivElement

  const LABEL_SETTINGS_KEY = 'filaman-filament-label-settings'

  function saveSettings() {
    localStorage.setItem(LABEL_SETTINGS_KEY, JSON.stringify({
      width: widthInput.value,
      height: heightInput.value,
      fontSize: fontSizeInput.value,
      qrSize: qrSizeInput.value,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
    }))
  }

  function loadSettings() {
    try {
      const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
      if (!saved) return
      const settings = JSON.parse(saved)
      if (settings.width != null) widthInput.value = settings.width
      if (settings.height != null) heightInput.value = settings.height
      if (settings.fontSize != null) fontSizeInput.value = settings.fontSize
      if (settings.qrSize != null) qrSizeInput.value = settings.qrSize
      if (settings.showQR !== undefined) checkQR.checked = settings.showQR
      if (settings.showID !== undefined) checkID.checked = settings.showID
      if (settings.showMfr !== undefined) checkMfr.checked = settings.showMfr
      if (settings.showMat !== undefined) checkMat.checked = settings.showMat
      if (settings.showColor !== undefined) checkColor.checked = settings.showColor
    } catch {
      // ignore corrupt local settings
    }
  }

  loadSettings()

  document.getElementById('title-settings')!.textContent = (window as any).__t('filaments.printSettings')
  document.getElementById('label-width-text')!.textContent = (window as any).__t('filaments.labelWidth')
  document.getElementById('label-height-text')!.textContent = (window as any).__t('filaments.labelHeight')
  document.getElementById('label-font-size-text')!.textContent = (window as any).__t('filaments.fontSize')
  document.getElementById('label-qr-size-text')!.textContent = (window as any).__t('filaments.qrSize')
  document.getElementById('label-show-qr')!.textContent = (window as any).__t('filaments.showQRCode')
  document.getElementById('label-show-mfr')!.textContent = (window as any).__t('filaments.showManufacturer')
  document.getElementById('label-show-mat')!.textContent = (window as any).__t('filaments.showMaterial')
  document.getElementById('label-show-color')!.textContent = (window as any).__t('filaments.showColor')
  document.getElementById('btn-print')!.textContent = (window as any).__t('common.print')
  document.getElementById('btn-reset')!.textContent = (window as any).__t('filaments.resetDefaults')
  document.getElementById('title-display')!.textContent = (window as any).__t('filaments.printDisplay')
  document.getElementById('label-show-id')!.textContent = (window as any).__t('filaments.showFilamentId')

  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  backBtn.href = `/filaments/${id}`
  document.getElementById('label-back')!.textContent = (window as any).__t('filaments.backToFilament')

  function getColorDisplay(filament: any): string {
    if (filament.manufacturer_color_name) {
      return filament.manufacturer_color_name
    }

    if (Array.isArray(filament.colors) && filament.colors.length > 0) {
      return filament.colors
        .map((entry: any) => entry.display_name_override || entry.color?.name || '')
        .filter(Boolean)
        .join(', ')
    }

    return ''
  }

  async function loadFilamentData() {
    try {
      const response = await fetch(`/api/v1/filaments/${id}`, { credentials: 'include' })
      if (!response.ok) {
        throw new Error('Failed to fetch filament for print')
      }

      const filament = await response.json()
      labelData = {
        id: String(filament.id ?? id),
        designation: filament.designation || '',
        manufacturer: filament.manufacturer?.name || '',
        type: filament.material_type || '',
        color: getColorDisplay(filament),
      }
    } catch (error) {
      console.error('Failed to load filament print data:', error)
      const errorEl = document.getElementById('load-error') as HTMLDivElement | null
      if (errorEl) {
        errorEl.textContent = (window as any).__t?.('filaments.loadError') || 'Failed to load filament data.'
        errorEl.style.display = 'block'
      }
    }
  }

  let qrCodeReady: Promise<void> | null = null
  function ensureQRCode(): Promise<void> {
    if (typeof (window as any).QRCode !== 'undefined') return Promise.resolve()
    if (!qrCodeReady) {
      qrCodeReady = new Promise((resolve, reject) => {
        const script = document.createElement('script')
        script.src = '/vendor/qrcode.min.js'
        script.onload = () => resolve()
        script.onerror = reject
        document.head.appendChild(script)
      })
    }
    return qrCodeReady
  }

  async function updatePreview() {
    await ensureQRCode()

    const width = widthInput.value
    const height = heightInput.value
    const qrSize = qrSizeInput.value
    const fontSizeBase = parseInt(fontSizeInput.value, 10) / 100

    labelPreview.style.width = width + 'mm'
    labelPreview.style.height = height + 'mm'

    ;(document.getElementById('prev-id') as HTMLDivElement).style.fontSize = (fontSizeBase * 14) + 'pt'
    ;(document.getElementById('prev-filament') as HTMLDivElement).style.fontSize = (fontSizeBase * 9) + 'pt'
    ;(document.getElementById('prev-mfr') as HTMLDivElement).style.fontSize = (fontSizeBase * 7.5) + 'pt'
    ;(document.getElementById('prev-color') as HTMLDivElement).style.fontSize = (fontSizeBase * 7.5) + 'pt'

    qrContainer.style.display = checkQR.checked ? 'block' : 'none'
    document.getElementById('prev-id')!.style.display = checkID.checked ? 'block' : 'none'

    const mfrText = checkMfr.checked ? labelData.manufacturer : ''
    const matText = checkMat.checked ? labelData.type : ''
    document.getElementById('prev-mfr')!.textContent = [mfrText, matText].filter(Boolean).join(' - ')
    document.getElementById('prev-mfr')!.style.display = (checkMfr.checked || checkMat.checked) ? 'block' : 'none'

    document.getElementById('prev-color')!.textContent = checkColor.checked ? labelData.color : ''
    document.getElementById('prev-color')!.style.display = checkColor.checked ? 'block' : 'none'

    document.getElementById('prev-id')!.textContent = `#${labelData.id}`
    document.getElementById('prev-filament')!.textContent = labelData.designation

    if (checkQR.checked) {
      qrContainer.innerHTML = ''
      const url = window.location.origin + '/filaments/' + labelData.id
      const qrPx = Math.round(parseInt(qrSize, 10) * 3.78)

      // @ts-ignore
      new QRCode(qrContainer, {
        text: url,
        width: qrPx,
        height: qrPx,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: (window as any).QRCode.CorrectLevel.H,
      })

      qrContainer.style.width = qrSize + 'mm'
      qrContainer.style.height = qrSize + 'mm'

      const canvas = qrContainer.querySelector('canvas')
      if (canvas) {
        const ctx = (canvas as HTMLCanvasElement).getContext('2d')
        if (ctx) {
          const fontSize = Math.round(qrPx * 0.13)
          ctx.font = `700 ${fontSize}px "Space Grotesk", sans-serif`
          ctx.textAlign = 'center'
          ctx.textBaseline = 'middle'
          const text = 'FilaMan'
          const metrics = ctx.measureText(text)
          const tw = metrics.width
          const th = fontSize
          const pad = Math.round(fontSize * 0.3)
          const cx = qrPx / 2
          const cy = qrPx / 2
          ctx.fillStyle = '#ffffff'
          ctx.fillRect(cx - tw / 2 - pad, cy - th / 2 - pad, tw + pad * 2, th + pad * 2)
          ctx.fillStyle = '#000000'
          ctx.fillText(text, cx, cy)
        }

        const dataUrl = (canvas as HTMLCanvasElement).toDataURL('image/png')
        qrContainer.innerHTML = ''
        const img = document.createElement('img')
        img.src = dataUrl
        img.style.width = '100%'
        img.style.height = '100%'
        img.style.display = 'block'
        qrContainer.appendChild(img)
      }

      qrContainer.style.flexShrink = '0'
    }

    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    const style = document.createElement('style')
    const pageRule = isSafari ? '' : `@page { size: ${width}mm ${height}mm; margin: 0; }`
    style.textContent = `
      ${pageRule}
      @media print {
        .label-preview {
          width: ${width}mm !important;
          height: ${height}mm !important;
          min-width: ${width}mm !important;
          min-height: ${height}mm !important;
          max-width: ${width}mm !important;
          max-height: ${height}mm !important;
        }
      }
    `
    const oldStyle = document.querySelector('style#page-style')
    if (oldStyle) oldStyle.remove()
    style.id = 'page-style'
    document.head.appendChild(style)
    saveSettings()
  }

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkQR, checkID, checkMfr, checkMat, checkColor].forEach((element) => {
    element.addEventListener('change', updatePreview)
    if (element.type === 'range' || element.type === 'number') {
      element.addEventListener('input', updatePreview)
    }
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(LABEL_SETTINGS_KEY)
    widthInput.value = '60'
    heightInput.value = '25'
    fontSizeInput.value = '100'
    qrSizeInput.value = '22'
    checkQR.checked = true
    checkID.checked = true
    checkMfr.checked = true
    checkMat.checked = true
    checkColor.checked = true
    updatePreview()
  })

  loadFilamentData().finally(() => {
    updatePreview()
  })
</script>