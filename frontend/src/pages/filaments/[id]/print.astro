---
import Layout from '../../../layouts/Layout.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}

const { id } = Astro.params
---

<Layout title="FilaMan - Print Filament Label">
  <div class="print-page">
    <aside class="print-sidebar">
      <a id="btn-back" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="label-back">Back to Filament</span>
      </a>

      <div class="settings-section">
        <h3 id="title-settings">Print Settings</h3>

        <div>
          <label class="fm-label" id="label-width-text">Width (mm)</label>
          <input type="number" id="input-width" value="60" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-height-text">Height (mm)</label>
          <input type="number" id="input-height" value="25" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-font-size-text">Font Size (%)</label>
          <input type="range" id="input-font-size" min="50" max="200" value="100" class="fm-input" style="padding: 8px;">
        </div>

        <div>
          <label class="fm-label" id="label-qr-size-text">QR Size (mm)</label>
          <input type="number" id="input-qr-size" value="22" class="fm-input">
        </div>

        <h3 id="title-display">Display</h3>
        <div class="checkbox-grid">
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-qr" checked>
            <span id="label-show-qr">QR Code</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-id" checked>
            <span id="label-show-id">Filament ID</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mfr" checked>
            <span id="label-show-mfr">Manufacturer</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mat" checked>
            <span id="label-show-mat">Material</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color" checked>
            <span id="label-show-color">Color</span>
          </label>
        </div>
      </div>

      <details class="export-panel">
        <summary class="export-summary">
          <span id="title-export">Export</span>
          <span class="export-summary-caret" aria-hidden="true"></span>
        </summary>
        <div class="export-body">
          <div>
            <label class="fm-label" id="label-export-format">Format</label>
            <select id="select-export-format" class="fm-input">
              <option id="option-export-png" value="png">PNG</option>
              <option id="option-export-aml" value="aml">AML</option>
            </select>
          </div>

          <div id="export-dpi-group">
            <label class="fm-label export-inline-label">
              <span id="label-export-dpi">DPI</span>
              <span id="value-export-dpi">300</span>
            </label>
            <input type="range" id="input-export-dpi" min="72" max="600" value="300" class="fm-input" style="padding: 8px;">
          </div>

          <div class="export-meta">
            <div class="export-meta-label" id="label-planned-filename">Planned file name</div>
            <div class="export-meta-value" id="preview-filename">filament-label.png</div>
          </div>

          <button id="btn-export" class="fm-btn fm-btn-primary export-action-button" type="button">
            <svg class="export-action-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><path d="M17 21v-8H7v8"/><path d="M7 3v5h8"/></svg>
            <span id="btn-export-label">Export PNG</span>
          </button>
        </div>
      </details>

      <div class="action-buttons">
        <button id="btn-print" class="fm-btn fm-btn-primary" onclick="filamanPrint()">Print</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline">Reset</button>
      </div>
    </aside>

    <main class="preview-container">
      <div id="label-preview" class="label-preview">
        <div id="label-qr-container"></div>
        <div id="label-text-container" style="display: flex; flex-direction: column; justify-content: center; min-width: 0; line-height: 1.1;">
          <div id="prev-id" style="font-size: 1.4em; font-weight: 700; margin-bottom: 2px;"></div>
          <div id="prev-filament" style="font-size: 0.9em; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
          <div id="prev-mfr" style="font-size: 0.8em; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
          <div id="prev-color" style="font-size: 0.8em; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .print-page {
    display: flex;
    height: calc(100vh - 64px);
    margin: -32px;
    overflow: hidden;
  }

  .print-sidebar {
    width: 320px;
    background: var(--bg-elevated);
    border-right: 1px solid var(--border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity var(--transition);
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .settings-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .settings-section h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-muted);
    margin: 0;
  }

  .export-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
  }

  .export-summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-muted);
  }

  .export-summary::-webkit-details-marker {
    display: none;
  }

  .export-summary-caret {
    width: 9px;
    height: 9px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    transition: transform var(--transition);
    margin-top: -3px;
  }

  .export-panel[open] .export-summary-caret {
    transform: rotate(225deg);
    margin-top: 3px;
  }

  .export-body {
    padding: 0 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .export-inline-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .export-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .export-meta-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-muted);
  }

  .export-meta-value {
    font-size: 0.74rem;
    font-family: ui-monospace, SFMono-Regular, SF Mono, Menlo, Monaco, Consolas, Liberation Mono, monospace;
    line-height: 1.45;
    color: var(--text);
    word-break: break-word;
  }

  .export-action-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .export-action-icon {
    flex-shrink: 0;
  }

  .preview-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    overflow: auto;
    background: var(--bg-soft);
  }

  .label-preview {
    background: white;
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    padding: 1.5mm;
    box-sizing: border-box;
    gap: 3mm;
    overflow: hidden;
    position: relative;
    border: 1px dashed #ccc;
    border-radius: 4px;
  }

  .label-preview.is-exporting-label {
    box-shadow: none;
    border: none;
    border-radius: 0;
  }

  #label-text-container {
    flex: 1;
    min-width: 0;
    color: black;
  }

  .fm-label {
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 6px;
    display: block;
    color: var(--text);
  }

  .fm-input {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
    height: 42px;
    box-sizing: border-box;
  }

  .fm-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }

  .fm-checkbox-group {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: background var(--transition);
  }

  .fm-checkbox-group:hover {
    background: var(--bg-soft);
  }

  .fm-checkbox-group input {
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .fm-checkbox-group span {
    font-size: 0.9rem;
    color: var(--text);
  }

  .fm-btn {
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.2px;
    cursor: pointer;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    font-family: var(--font-sans);
  }

  .fm-btn-primary {
    background: var(--accent);
    color: var(--btn-primary-text);
    box-shadow: var(--glow);
  }

  .fm-btn-primary:hover {
    transform: translateY(-2px);
  }

  .fm-btn-outline {
    background: transparent;
    border-color: var(--border);
    color: var(--text);
  }

  .fm-btn-outline:hover {
    background: var(--bg-soft);
  }

  .action-buttons {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }
</style>

<style is:global>
  @media print {
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    .fm-sidebar,
    #fm-confirm-overlay,
    .fm-sidebar-backdrop {
      display: none !important;
    }

    .fm-page {
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      background: white !important;
      min-height: 0 !important;
      height: auto !important;
      position: static !important;
    }

    .fm-page > main {
      padding: 0 !important;
      margin: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    .print-sidebar {
      display: none !important;
    }

    .print-page {
      margin: 0 !important;
      height: auto !important;
      display: block !important;
    }

    .preview-container {
      padding: 0 !important;
      margin: 0 !important;
      display: block !important;
      overflow: visible !important;
      background: white !important;
    }

    .label-preview {
      box-shadow: none !important;
      border: none !important;
      border-radius: 0 !important;
      display: flex !important;
      align-items: center !important;
      gap: 3mm !important;
      background: white !important;
      color: black !important;
      margin: 0 !important;
      padding: 1.5mm !important;
      overflow: hidden !important;
      break-inside: avoid !important;
      page-break-inside: avoid !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .label-preview div,
    .label-preview span {
      color: black !important;
    }

    #label-qr-container {
      flex-shrink: 0 !important;
    }

    #label-qr-container img {
      display: block !important;
    }
  }
</style>

<script>
  import { buildPlannedFileName, exportLabelAsAml, exportLabelAsPng } from '../../../lib/label-export'

  ;(window as any).filamanPrint = function() {
    try {
      document.execCommand('print', false, null)
    } catch {
      window.print()
    }
  }

  // The Astro route is scaffolded with a placeholder id, so query params carry the real label data.
  const pathId = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]
  const params = new URLSearchParams(window.location.search)
  const id = params.get('id') || pathId
  let labelData = {
    id,
    designation: params.get('designation') || '',
    manufacturer: params.get('mfr') || '',
    type: params.get('type') || '',
    color: params.get('color') || '',
  }

  const widthInput = document.getElementById('input-width') as HTMLInputElement
  const heightInput = document.getElementById('input-height') as HTMLInputElement
  const fontSizeInput = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput = document.getElementById('input-qr-size') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const exportFormatSelect = document.getElementById('select-export-format') as HTMLSelectElement
  const exportDpiInput = document.getElementById('input-export-dpi') as HTMLInputElement
  const exportDpiGroup = document.getElementById('export-dpi-group') as HTMLDivElement
  const exportDpiValue = document.getElementById('value-export-dpi') as HTMLSpanElement
  const previewFilename = document.getElementById('preview-filename') as HTMLDivElement
  const exportButton = document.getElementById('btn-export') as HTMLButtonElement
  const exportButtonLabel = document.getElementById('btn-export-label') as HTMLSpanElement
  const labelPreview = document.getElementById('label-preview') as HTMLDivElement
  const qrContainer = document.getElementById('label-qr-container') as HTMLDivElement

  const LABEL_SETTINGS_KEY = 'filaman-filament-label-settings'

  function saveSettings() {
    localStorage.setItem(LABEL_SETTINGS_KEY, JSON.stringify({
      width: widthInput.value,
      height: heightInput.value,
      fontSize: fontSizeInput.value,
      qrSize: qrSizeInput.value,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
      exportFormat: exportFormatSelect.value,
      exportDpi: exportDpiInput.value,
    }))
  }

  function loadSettings() {
    try {
      const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
      if (!saved) return
      const settings = JSON.parse(saved)
      if (settings.width) widthInput.value = settings.width
      if (settings.height) heightInput.value = settings.height
      if (settings.fontSize) fontSizeInput.value = settings.fontSize
      if (settings.qrSize) qrSizeInput.value = settings.qrSize
      if (settings.showQR !== undefined) checkQR.checked = settings.showQR
      if (settings.showID !== undefined) checkID.checked = settings.showID
      if (settings.showMfr !== undefined) checkMfr.checked = settings.showMfr
      if (settings.showMat !== undefined) checkMat.checked = settings.showMat
      if (settings.showColor !== undefined) checkColor.checked = settings.showColor
      if (settings.exportFormat) exportFormatSelect.value = settings.exportFormat
      if (settings.exportDpi) exportDpiInput.value = settings.exportDpi
    } catch {
      // ignore corrupt local settings
    }
  }

  loadSettings()

  document.getElementById('title-settings')!.textContent = (window as any).__t('spools.printSettings')
  document.getElementById('label-width-text')!.textContent = (window as any).__t('spools.labelWidth')
  document.getElementById('label-height-text')!.textContent = (window as any).__t('spools.labelHeight')
  document.getElementById('label-font-size-text')!.textContent = (window as any).__t('spools.fontSize')
  document.getElementById('label-qr-size-text')!.textContent = (window as any).__t('spools.qrSize')
  document.getElementById('label-show-qr')!.textContent = (window as any).__t('spools.showQRCode')
  document.getElementById('label-show-mfr')!.textContent = (window as any).__t('spools.showManufacturer')
  document.getElementById('label-show-mat')!.textContent = (window as any).__t('spools.showMaterial')
  document.getElementById('label-show-color')!.textContent = (window as any).__t('spools.showColor')
  document.getElementById('btn-print')!.textContent = (window as any).__t('common.print')
  document.getElementById('btn-reset')!.textContent = (window as any).__t('spools.resetDefaults')
  document.getElementById('title-display')!.textContent = (window as any).__t('filaments.printDisplay')
  document.getElementById('label-show-id')!.textContent = (window as any).__t('filaments.showFilamentId')
  document.getElementById('title-export')!.textContent = (window as any).__t('common.export')
  document.getElementById('label-export-format')!.textContent = (window as any).__t('common.format')
  document.getElementById('label-export-dpi')!.textContent = (window as any).__t('common.dpi')
  document.getElementById('label-planned-filename')!.textContent = (window as any).__t('common.plannedFileName')
  document.getElementById('option-export-png')!.textContent = (window as any).__t('common.png')
  document.getElementById('option-export-aml')!.textContent = (window as any).__t('common.aml')

  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  backBtn.href = `/filaments/${id}`
  document.getElementById('label-back')!.textContent = (window as any).__t('filaments.backToFilament')

  function getSelectedExportFormat() {
    return exportFormatSelect.value === 'aml' ? 'aml' : 'png'
  }

  function getPlannedBaseFileName() {
    return buildPlannedFileName(
      [
        checkMfr.checked ? labelData.manufacturer : '',
        checkMat.checked ? labelData.type : '',
        labelData.designation,
        checkColor.checked ? labelData.color : '',
        checkID.checked ? `filament-${labelData.id}` : '',
      ],
      `filament-label-${labelData.id}`,
    )
  }

  async function renderQrCode(scale = 1) {
    qrContainer.innerHTML = ''
    const url = window.location.origin + '/filaments/' + labelData.id
    const qrPx = Math.max(1, Math.round(parseInt(qrSizeInput.value, 10) * 3.78 * scale))

    // @ts-ignore
    new QRCode(qrContainer, {
      text: url,
      width: qrPx,
      height: qrPx,
      colorDark: '#000000',
      colorLight: '#ffffff',
      correctLevel: (window as any).QRCode.CorrectLevel.H,
    })

    qrContainer.style.width = qrSizeInput.value + 'mm'
    qrContainer.style.height = qrSizeInput.value + 'mm'

    const canvas = qrContainer.querySelector('canvas')
    if (canvas) {
      const ctx = (canvas as HTMLCanvasElement).getContext('2d')
      if (ctx) {
        const fontSize = Math.round(qrPx * 0.13)
        ctx.font = `700 ${fontSize}px "Space Grotesk", sans-serif`
        ctx.textAlign = 'center'
        ctx.textBaseline = 'middle'
        const text = 'FilaMan'
        const metrics = ctx.measureText(text)
        const tw = metrics.width
        const th = fontSize
        const pad = Math.round(fontSize * 0.3)
        const cx = qrPx / 2
        const cy = qrPx / 2
        ctx.fillStyle = '#ffffff'
        ctx.fillRect(cx - tw / 2 - pad, cy - th / 2 - pad, tw + pad * 2, th + pad * 2)
        ctx.fillStyle = '#000000'
        ctx.fillText(text, cx, cy)
      }

      const dataUrl = (canvas as HTMLCanvasElement).toDataURL('image/png')
      qrContainer.innerHTML = ''
      const img = document.createElement('img')
      img.src = dataUrl
      img.style.width = '100%'
      img.style.height = '100%'
      img.style.display = 'block'
      qrContainer.appendChild(img)
    }

    qrContainer.style.flexShrink = '0'
  }

  function updateExportUi() {
    const format = getSelectedExportFormat()
    const exportLabel = document.getElementById('title-export')?.textContent?.trim() || 'Export'
    const formatLabel = exportFormatSelect.selectedOptions[0]?.textContent?.trim() || format.toUpperCase()
    exportDpiGroup.style.display = 'block'
    exportDpiValue.textContent = exportDpiInput.value
    previewFilename.textContent = `${getPlannedBaseFileName()}.${format}`
    exportButtonLabel.textContent = `${exportLabel} ${formatLabel}`
  }

  function getColorDisplay(filament: any): string {
    if (filament.manufacturer_color_name) {
      return filament.manufacturer_color_name
    }

    if (Array.isArray(filament.colors) && filament.colors.length > 0) {
      return filament.colors
        .map((entry: any) => entry.display_name_override || entry.color?.name || '')
        .filter(Boolean)
        .join(', ')
    }

    return ''
  }

  async function loadFilamentData() {
    try {
      const response = await fetch(`/api/v1/filaments/${id}`, { credentials: 'include' })
      if (!response.ok) {
        throw new Error('Failed to fetch filament for print')
      }

      const filament = await response.json()
      labelData = {
        id: String(filament.id ?? id),
        designation: filament.designation || '',
        manufacturer: filament.manufacturer?.name || '',
        type: filament.material_type || '',
        color: getColorDisplay(filament),
      }
    } catch (error) {
      console.error('Failed to load filament print data:', error)
    }

    updateExportUi()
  }

  async function updatePreview() {
    if (typeof (window as any).QRCode === 'undefined') {
      await new Promise((resolve, reject) => {
        const script = document.createElement('script')
        script.src = '/vendor/qrcode.min.js'
        script.onload = resolve
        script.onerror = reject
        document.head.appendChild(script)
      })
    }

    const width = widthInput.value
    const height = heightInput.value
    const qrSize = qrSizeInput.value
    const fontSizeBase = parseInt(fontSizeInput.value, 10) / 100

    labelPreview.style.width = width + 'mm'
    labelPreview.style.height = height + 'mm'

    ;(document.getElementById('prev-id') as HTMLDivElement).style.fontSize = (fontSizeBase * 14) + 'pt'
    ;(document.getElementById('prev-filament') as HTMLDivElement).style.fontSize = (fontSizeBase * 9) + 'pt'
    ;(document.getElementById('prev-mfr') as HTMLDivElement).style.fontSize = (fontSizeBase * 7.5) + 'pt'
    ;(document.getElementById('prev-color') as HTMLDivElement).style.fontSize = (fontSizeBase * 7.5) + 'pt'

    qrContainer.style.display = checkQR.checked ? 'block' : 'none'
    document.getElementById('prev-id')!.style.display = checkID.checked ? 'block' : 'none'

    const mfrText = checkMfr.checked ? labelData.manufacturer : ''
    const matText = checkMat.checked ? labelData.type : ''
    document.getElementById('prev-mfr')!.textContent = [mfrText, matText].filter(Boolean).join(' - ')
    document.getElementById('prev-mfr')!.style.display = (checkMfr.checked || checkMat.checked) ? 'block' : 'none'

    document.getElementById('prev-color')!.textContent = checkColor.checked ? labelData.color : ''
    document.getElementById('prev-color')!.style.display = checkColor.checked ? 'block' : 'none'

    document.getElementById('prev-id')!.textContent = `#${labelData.id}`
    document.getElementById('prev-filament')!.textContent = labelData.designation

    if (checkQR.checked) {
      await renderQrCode()
    }

    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    const style = document.createElement('style')
    const pageRule = isSafari ? '' : `@page { size: ${width}mm ${height}mm; margin: 0; }`
    style.innerHTML = `
      ${pageRule}
      @media print {
        .label-preview {
          width: ${width}mm !important;
          height: ${height}mm !important;
          min-width: ${width}mm !important;
          min-height: ${height}mm !important;
          max-width: ${width}mm !important;
          max-height: ${height}mm !important;
        }
      }
    `
    const oldStyle = document.querySelector('style#page-style')
    if (oldStyle) oldStyle.remove()
    style.id = 'page-style'
    document.head.appendChild(style)
    updateExportUi()
    saveSettings()
  }

  ;[checkID, checkMfr, checkMat, checkColor].forEach((element) => {
    element.addEventListener('change', updateExportUi)
  })

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkQR, checkID, checkMfr, checkMat, checkColor].forEach((element) => {
    element.addEventListener('change', updatePreview)
    if (element.type === 'range' || element.type === 'number') {
      element.addEventListener('input', updatePreview)
    }
  })

  ;[exportFormatSelect, exportDpiInput].forEach((element) => {
    element.addEventListener('input', () => {
      updateExportUi()
      saveSettings()
    })
    element.addEventListener('change', () => {
      updateExportUi()
      saveSettings()
    })
    if (element.type === 'range') {
      element.addEventListener('input', () => {
        updateExportUi()
        saveSettings()
      })
    }
  })

  async function runExport(saveMode: 'download' | 'save-as' = 'download') {
    const fileName = getPlannedBaseFileName()
    const dpi = parseInt(exportDpiInput.value, 10) || 300
    const widthMm = parseFloat(widthInput.value) || 60
    const heightMm = parseFloat(heightInput.value) || 25
    const exportScale = Math.max(1, Math.min(dpi / 96, 10))

    try {
      if (checkQR.checked) {
        await renderQrCode(exportScale)
      }

      if (getSelectedExportFormat() === 'aml') {
        await exportLabelAsAml(labelPreview, fileName, dpi, widthMm, heightMm, saveMode)
      } else {
        await exportLabelAsPng(labelPreview, fileName, dpi, saveMode)
      }
    } catch (error) {
      console.error('Failed to export filament label:', error)
    } finally {
      if (checkQR.checked) {
        await renderQrCode()
      }
    }
  }

  exportButton.addEventListener('click', async () => {
    await runExport('download')
  })

  exportButton.addEventListener('contextmenu', async (event) => {
    event.preventDefault()
    await runExport('save-as')
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(LABEL_SETTINGS_KEY)
    widthInput.value = '60'
    heightInput.value = '25'
    fontSizeInput.value = '100'
    qrSizeInput.value = '22'
    checkQR.checked = true
    checkID.checked = true
    checkMfr.checked = true
    checkMat.checked = true
    checkColor.checked = true
    exportFormatSelect.value = 'png'
    exportDpiInput.value = '300'
    updatePreview()
  })

  updateExportUi()

  loadFilamentData().finally(() => {
    updatePreview()
  })
</script>