</style>

<script>
  import { parseTemplate, renderTemplateText } from '../../../lib/label-template'
  import type { SpoolData } from '../../../lib/label-template'

  // Global print function for Safari compatibility
  ;(window as any).filamanPrint = function() {
    try {
      // Try execCommand first (better Safari support)
      document.execCommand('print', false, null)
    } catch (e) {
      // Fallback to window.print
      window.print()
    }
  }

  const id = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]

  const params = new URLSearchParams(window.location.search)
  const labelData = {
    id: id,
    designation: params.get('designation') || '',
    manufacturer: params.get('mfr') || '',
    type: params.get('type') || '',
    color: params.get('color') || '',
    mfr_id: params.get('mfr_id') || '',
    hex_code: params.get('hex_code') || '',
    extruder_temp: params.get('extruder_temp') || '',
    bed_temp: params.get('bed_temp') || '',
    weight: params.get('weight') || '',
  }

  let extraFields: {key: string, label: string, value: string, source?: string}[] = []
  try {
    const stored = sessionStorage.getItem('filaman-label-extra-fields')
    if (stored) extraFields = JSON.parse(stored)
  } catch(e) { /* ignore */ }

  // Flat SpoolData object consumed by the template parser (Phase 3)
  // Keys match the {token} names used in designer templates.
  function buildSpoolData() {
    const extra: Record<string, string> = {}
    for (const ef of extraFields) extra[ef.key] = ef.value
    return {
      id: labelData.id,
      'filament.name': labelData.designation,
      'filament.material': labelData.type,
      'filament.color': labelData.color,
      'filament.color_hex': labelData.hex_code,
      'filament.manufacturer': labelData.manufacturer,
      'filament.extruder_temp': labelData.extruder_temp,
      'filament.bed_temp': labelData.bed_temp,
      'filament.weight': labelData.weight,
      extra,
    }
  }

  // DOM references
  const widthInput = document.getElementById('input-width')
  const heightInput = document.getElementById('input-height')
  const fontSizeInput = document.getElementById('input-font-size')
  const qrSizeInput = document.getElementById('input-qr-size')
  const checkLogo = document.getElementById('check-logo') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const checkColorSwatch = document.getElementById('check-color-swatch') as HTMLInputElement
  const labelPreview = document.getElementById('label-preview')
  const qrContainer = document.getElementById('label-qr-container')

  const LABEL_SETTINGS_KEY = 'filaman-label-settings'
  const ACTIVE_TAB_KEY = 'filaman-label-active-tab'

  // --- Tab switching ---
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  const tabPanelPrint = document.getElementById('tab-panel-print')
  const tabPanelDesigner = document.getElementById('tab-panel-designer')

  function activateTab(tab: 'print' | 'designer') {
    tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === tab))
    tabPanelPrint.style.display = tab === 'print' ? '' : 'none'
    tabPanelDesigner.style.display = tab === 'designer' ? '' : 'none'
    localStorage.setItem(ACTIVE_TAB_KEY, tab)
    // Trigger the appropriate preview when switching tabs
    if (tab === 'designer') updateDesignerPreview()
    else updatePreview()
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => activateTab(btn.dataset.tab as 'print' | 'designer'))
  })

  // Restore last active tab
  const savedTab = localStorage.getItem(ACTIVE_TAB_KEY)
  if (savedTab === 'designer') activateTab('designer')

  // ─── Label Designer ────────────────────────────────────────────────────────

  const DESIGNER_KEY = 'filaman-label-designer-v1'

  interface LabelDesignerSettings {
    label:  { width: number; height: number; border: boolean }
    title:  { show: boolean; sizeMm: number; fitToWidth: boolean; align: 'left'|'center'|'right'; template: string }
    qr:     { mode: 'none'|'simple'|'icon'; sizeMm: number; position: 'left'|'right'; vAlign: 'top'|'center'|'bottom'; linkMode: 'spool'|'url'; urlTemplate: string }
    info:   { show: boolean; sizeMm: number; hAlign: 'left'|'center'|'right'; vAlign: 'top'|'center'|'bottom'; template: string }
  }

  const DESIGNER_DEFAULTS: LabelDesignerSettings = {
    label:  { width: 60, height: 40, border: false },
    title:  { show: true, sizeMm: 4, fitToWidth: true, align: 'left', template: '{filament.name}' },
    qr:     { mode: 'simple', sizeMm: 18, position: 'right', vAlign: 'bottom', linkMode: 'spool', urlTemplate: '' },
    info:   { show: true, sizeMm: 2.5, hAlign: 'left', vAlign: 'bottom',
              template: '{filament.material}\n{filament.color}\nExt: {filament.extruder_temp}°C\nBed: {filament.bed_temp}°C' },
  }

  // All available tokens for the token-chip hints
  const DESIGNER_TOKENS = [
    '{id}', '{filament.name}', '{filament.material}', '{filament.color}',
    '{filament.color_hex}', '{filament.manufacturer}',
    '{filament.extruder_temp}', '{filament.bed_temp}', '{filament.weight}',
  ]

  function saveDesignerSettings() {
    const s: LabelDesignerSettings = {
      label: {
        width:  Number((document.getElementById('ds-width') as HTMLInputElement).value),
        height: Number((document.getElementById('ds-height') as HTMLInputElement).value),
        border: (document.getElementById('ds-border') as HTMLInputElement).checked,
      },
      title: {
        show:       (document.getElementById('ds-title-show') as HTMLInputElement).checked,
        sizeMm:     Number((document.getElementById('ds-title-size') as HTMLInputElement).value),
        fitToWidth: (document.getElementById('ds-title-fit') as HTMLInputElement).checked,
        align:      (document.getElementById('ds-title-align-group') as HTMLElement).dataset.value as 'left'|'center'|'right',
        template:   (document.getElementById('ds-title-tpl') as HTMLInputElement).value,
      },
      qr: {
        mode:        (document.getElementById('ds-qr-mode') as HTMLSelectElement).value as 'none'|'simple'|'icon',
        sizeMm:      Number((document.getElementById('ds-qr-size') as HTMLInputElement).value),
        position:    (document.getElementById('ds-qr-pos-group') as HTMLElement).dataset.value as 'left'|'right',
        vAlign:      (document.getElementById('ds-qr-valign-group') as HTMLElement).dataset.value as 'top'|'center'|'bottom',
        linkMode:    (document.getElementById('ds-qr-link-group') as HTMLElement).dataset.value as 'spool'|'url',
        urlTemplate: (document.getElementById('ds-qr-url-tpl') as HTMLInputElement).value,
      },
      info: {
        show:   (document.getElementById('ds-info-show') as HTMLInputElement).checked,
        sizeMm: Number((document.getElementById('ds-info-size') as HTMLInputElement).value),
        hAlign: (document.getElementById('ds-info-align-group') as HTMLElement).dataset.value as 'left'|'center'|'right',
        vAlign: (document.getElementById('ds-info-valign-group') as HTMLElement).dataset.value as 'top'|'center'|'bottom',
        template: (document.getElementById('ds-info-tpl') as HTMLTextAreaElement).value,
      },
    }
    localStorage.setItem(DESIGNER_KEY, JSON.stringify(s))
  }

  function loadDesignerSettings() {
    let s: LabelDesignerSettings = DESIGNER_DEFAULTS
    try {
      const raw = localStorage.getItem(DESIGNER_KEY)
      if (raw) s = { ...DESIGNER_DEFAULTS, ...JSON.parse(raw) }
    } catch { /* ignore */ }

    ;(document.getElementById('ds-width') as HTMLInputElement).value = String(s.label.width)
    ;(document.getElementById('ds-height') as HTMLInputElement).value = String(s.label.height)
    ;(document.getElementById('ds-border') as HTMLInputElement).checked = s.label.border

    ;(document.getElementById('ds-title-show') as HTMLInputElement).checked = s.title.show
    ;(document.getElementById('ds-title-size') as HTMLInputElement).value = String(s.title.sizeMm)
    ;(document.getElementById('ds-title-fit') as HTMLInputElement).checked = s.title.fitToWidth
    setAlignGroup('ds-title-align-group', s.title.align)
    ;(document.getElementById('ds-title-tpl') as HTMLInputElement).value = s.title.template

    ;(document.getElementById('ds-qr-mode') as HTMLSelectElement).value = s.qr.mode
    ;(document.getElementById('ds-qr-size') as HTMLInputElement).value = String(s.qr.sizeMm)
    setPillGroup('ds-qr-pos-group', s.qr.position)
    setPillGroup('ds-qr-valign-group', s.qr.vAlign)
    setPillGroup('ds-qr-link-group', s.qr.linkMode)
    ;(document.getElementById('ds-qr-url-tpl') as HTMLInputElement).value = s.qr.urlTemplate
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = s.qr.linkMode === 'url' ? '' : 'none'

    ;(document.getElementById('ds-info-show') as HTMLInputElement).checked = s.info.show
    ;(document.getElementById('ds-info-size') as HTMLInputElement).value = String(s.info.sizeMm)
    setAlignGroup('ds-info-align-group', s.info.hAlign)
    setPillGroup('ds-info-valign-group', s.info.vAlign)
    ;(document.getElementById('ds-info-tpl') as HTMLTextAreaElement).value = s.info.template
  }

  // Helpers for button groups
  function setAlignGroup(groupId: string, value: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.dataset.value = value
    group.querySelectorAll<HTMLButtonElement>('.ds-align-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.align === value)
    })
  }

  function setPillGroup(groupId: string, value: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.dataset.value = value
    group.querySelectorAll<HTMLButtonElement>('.ds-pill-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.val === value)
    })
  }

  function wireAlignGroup(groupId: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.querySelectorAll<HTMLButtonElement>('.ds-align-btn').forEach(btn => {
      btn.addEventListener('click', () => { setAlignGroup(groupId, btn.dataset.align!); saveDesignerSettings(); updateDesignerPreview() })
    })
  }

  function wirePillGroup(groupId: string, onChange?: (val: string) => void) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.querySelectorAll<HTMLButtonElement>('.ds-pill-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        setPillGroup(groupId, btn.dataset.val!)
        saveDesignerSettings()
        onChange?.(btn.dataset.val!)
        updateDesignerPreview()
      })
    })
  }

  function buildTokenChips(containerId: string, targetId: string, tokens: string[]) {
    const container = document.getElementById(containerId)
    if (!container) return
    for (const tok of tokens) {
      const chip = document.createElement('button')
      chip.className = 'ds-token-chip'
      chip.textContent = tok
      chip.title = tok
      chip.addEventListener('click', () => {
        const el = document.getElementById(targetId) as HTMLInputElement | HTMLTextAreaElement
        if (!el) return
        const start = el.selectionStart ?? el.value.length
        const end = el.selectionEnd ?? el.value.length
        el.value = el.value.slice(0, start) + tok + el.value.slice(end)
        el.selectionStart = el.selectionEnd = start + tok.length
        el.focus()
        saveDesignerSettings()
      })
      container.appendChild(chip)
    }
  }

  // Wire up all designer controls
  wireAlignGroup('ds-title-align-group')
  wireAlignGroup('ds-info-align-group')
  wirePillGroup('ds-qr-pos-group')
  wirePillGroup('ds-qr-valign-group')
  wirePillGroup('ds-info-valign-group')
  wirePillGroup('ds-qr-link-group', (val) => {
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = val === 'url' ? '' : 'none'
  })

  const dsInputIds = ['ds-width','ds-height','ds-title-size','ds-qr-size','ds-info-size','ds-title-tpl','ds-qr-url-tpl','ds-info-tpl']
  const dsCheckIds = ['ds-border','ds-title-show','ds-title-fit','ds-info-show']
  const dsSelectIds = ['ds-qr-mode']
  ;[...dsInputIds, ...dsCheckIds, ...dsSelectIds].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => { saveDesignerSettings(); updateDesignerPreview() })
  })
  dsInputIds.forEach(id => {
    const el = document.getElementById(id)
    if (el && (el as HTMLInputElement).type !== 'checkbox') {
      el.addEventListener('input', () => { saveDesignerSettings(); updateDesignerPreview() })
    }
  })

  // Token chips
  buildTokenChips('ds-title-tokens', 'ds-title-tpl', DESIGNER_TOKENS)
  buildTokenChips('ds-info-tokens', 'ds-info-tpl', DESIGNER_TOKENS)
  buildTokenChips('ds-qr-tokens', 'ds-qr-url-tpl', ['{id}', '{filament.name}'])

  // Load persisted designer settings
  loadDesignerSettings()

  // Per-section reset buttons
  function wireResetBtn(id: string, applyDefaults: () => void) {
    const btn = document.getElementById(id) as HTMLButtonElement | null
    if (!btn) return
    btn.addEventListener('click', (e) => {
      e.preventDefault()    // prevent <details> toggle
      e.stopPropagation()
      applyDefaults()
      saveDesignerSettings()
      updateDesignerPreview()
    })
  }

  wireResetBtn('dsr-label', () => {
    const d = DESIGNER_DEFAULTS.label
    ;(document.getElementById('ds-width') as HTMLInputElement).value = String(d.width)
    ;(document.getElementById('ds-height') as HTMLInputElement).value = String(d.height)
    ;(document.getElementById('ds-border') as HTMLInputElement).checked = d.border
  })

  wireResetBtn('dsr-title', () => {
    const d = DESIGNER_DEFAULTS.title
    ;(document.getElementById('ds-title-show') as HTMLInputElement).checked = d.show
    ;(document.getElementById('ds-title-size') as HTMLInputElement).value = String(d.sizeMm)
    ;(document.getElementById('ds-title-fit') as HTMLInputElement).checked = d.fitToWidth
    setAlignGroup('ds-title-align-group', d.align)
    ;(document.getElementById('ds-title-tpl') as HTMLInputElement).value = d.template
  })

  wireResetBtn('dsr-qr', () => {
    const d = DESIGNER_DEFAULTS.qr
    ;(document.getElementById('ds-qr-mode') as HTMLSelectElement).value = d.mode
    ;(document.getElementById('ds-qr-size') as HTMLInputElement).value = String(d.sizeMm)
    setPillGroup('ds-qr-pos-group', d.position)
    setPillGroup('ds-qr-valign-group', d.vAlign)
    setPillGroup('ds-qr-link-group', d.linkMode)
    ;(document.getElementById('ds-qr-url-tpl') as HTMLInputElement).value = d.urlTemplate
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = 'none'
  })

  wireResetBtn('dsr-info', () => {
    const d = DESIGNER_DEFAULTS.info
    ;(document.getElementById('ds-info-show') as HTMLInputElement).checked = d.show
    ;(document.getElementById('ds-info-size') as HTMLInputElement).value = String(d.sizeMm)
    setAlignGroup('ds-info-align-group', d.hAlign)
    setPillGroup('ds-info-valign-group', d.vAlign)
    ;(document.getElementById('ds-info-tpl') as HTMLTextAreaElement).value = d.template
  })

  // ─── End Label Designer ────────────────────────────────────────────────────

  // Label logo state
  let labelLogoUrl: string | null = null
  let labelLogoLoaded = false

  // Try to load the manufacturer's label-logo
  async function loadLabelLogo() {
    if (!labelData.mfr_id) return
    try {
      const resp = await fetch(`/api/v1/manufacturers/${labelData.mfr_id}/label-logo`, {
        credentials: 'include',
      })
      if (resp.ok) {
        const blob = await resp.blob()
        labelLogoUrl = URL.createObjectURL(blob)
        labelLogoLoaded = true
      }
    } catch {
      // Label logo not available — fall back to manufacturer name text
    }
  }

  // Build extra field checkboxes dynamically
  const extraFieldsTitle = document.getElementById('title-extra-fields')
  const extraFieldsCheckboxes = document.getElementById('extra-fields-checkboxes')
  const extraFieldChecks: {key: string, label: string, value: string, checkbox: HTMLInputElement}[] = []

  let savedExtraFieldSettings: Record<string, boolean> = {}
  try {
    const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
    if (saved) {
      const s = JSON.parse(saved)
      if (s.extraFields) savedExtraFieldSettings = s.extraFields
    }
  } catch(e) { /* ignore */ }

  if (extraFields.length > 0) {
    extraFieldsTitle.style.display = ''
    extraFieldsCheckboxes.style.display = ''
    const hasBothSources = extraFields.some(ef => ef.source === 'spool') && extraFields.some(ef => ef.source === 'filament')

    // Copy Astro scoped-style attribute from existing checkboxes so dynamic elements get the same styles
    const scopeAttr = (() => {
      const existing = document.querySelector('.fm-checkbox-group')
      if (!existing) return null
      return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
    })()

    for (const ef of extraFields) {
      const lbl = document.createElement('label')
      lbl.className = 'fm-checkbox-group'
      const cb = document.createElement('input')
      cb.type = 'checkbox'
      cb.id = `check-ef-${ef.key}`
      cb.checked = savedExtraFieldSettings[ef.key] || false
      const span = document.createElement('span')
      span.textContent = hasBothSources ? `${ef.label} (${ef.source === 'spool' ? ((window as any).__t('dashboard.spool') || 'Spool') : ((window as any).__t('spools.filament') || 'Filament')})` : ef.label
      if (scopeAttr) {
        lbl.setAttribute(scopeAttr.name, '')
        cb.setAttribute(scopeAttr.name, '')
        span.setAttribute(scopeAttr.name, '')
      }
      lbl.appendChild(cb)
      lbl.appendChild(span)
      extraFieldsCheckboxes.appendChild(lbl)
      extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
      cb.addEventListener('change', updatePreview)
    }
  }

  function saveSettings() {
    const settings: Record<string, any> = {
      width: (widthInput as HTMLInputElement).value,
      height: (heightInput as HTMLInputElement).value,
      fontSize: (fontSizeInput as HTMLInputElement).value,
      qrSize: (qrSizeInput as HTMLInputElement).value,
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      extraFields: extraFieldChecks.reduce((acc, ef) => {
        acc[ef.key] = ef.checkbox.checked
        return acc
      }, {} as Record<string, boolean>)
    }
    localStorage.setItem(LABEL_SETTINGS_KEY, JSON.stringify(settings))
  }

  function loadSettings() {
    try {
      const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
      if (!saved) return
      const s = JSON.parse(saved)
      if (s.width) (widthInput as HTMLInputElement).value = s.width
      if (s.height) (heightInput as HTMLInputElement).value = s.height
      if (s.fontSize) (fontSizeInput as HTMLInputElement).value = s.fontSize
      if (s.qrSize) (qrSizeInput as HTMLInputElement).value = s.qrSize
      if (s.showLogo !== undefined) checkLogo.checked = s.showLogo
      if (s.showQR !== undefined) checkQR.checked = s.showQR
      if (s.showID !== undefined) checkID.checked = s.showID
      if (s.showMfr !== undefined) checkMfr.checked = s.showMfr
      if (s.showMat !== undefined) checkMat.checked = s.showMat
      if (s.showColor !== undefined) checkColor.checked = s.showColor
      if (s.showColorSwatch !== undefined) checkColorSwatch.checked = s.showColorSwatch
    } catch (e) { /* ignore corrupt data */ }
  }

  loadSettings()

  document.getElementById('tab-btn-print').textContent = (window as any).__t('spools.printSettings') || 'Print Settings'
  document.getElementById('tab-btn-designer').textContent = (window as any).__t('spools.labelDesigner') || 'Label Designer'
  document.getElementById('title-settings').textContent = (window as any).__t('spools.printSettings')

  // Designer section headers + labels
  const t = (key: string, fallback: string) => (window as any).__t(key) || fallback
