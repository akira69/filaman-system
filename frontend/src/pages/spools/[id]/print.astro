---
import Layout from '../../../layouts/Layout.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}

const { id } = Astro.params
---

<Layout title="FilaMan - Print Label">
  <div class="print-page">
    <aside class="print-sidebar">
      <a id="btn-back" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="label-back">Zurück zur Spule</span>
      </a>

      <div class="settings-section">
        <h3 id="title-settings">Print Settings</h3>

        <div>
          <label class="fm-label" id="label-width-text">Breite (mm)</label>
          <input type="number" id="input-width" value="60" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-height-text">Höhe (mm)</label>
          <input type="number" id="input-height" value="40" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-font-size-text">Schriftgröße (%)</label>
          <input type="range" id="input-font-size" min="50" max="200" value="100" class="fm-input" style="padding: 8px;">
        </div>

        <div>
          <label class="fm-label" id="label-qr-size-text">QR-Größe (mm)</label>
          <input type="number" id="input-qr-size" value="18" class="fm-input">
        </div>

        <h3>Anzeige</h3>
        <div class="checkbox-grid">
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-logo" checked>
            <span id="label-show-logo">Logo</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-qr" checked>
            <span id="label-show-qr">QR-Code</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-id" checked>
            <span id="label-show-id">Spool-ID</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mfr" checked>
            <span id="label-show-mfr">Hersteller</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mat" checked>
            <span id="label-show-mat">Material</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color" checked>
            <span id="label-show-color">Farbe</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color-swatch" checked>
            <span id="label-show-color-swatch">Farbbalken</span>
          </label>
        </div>

        <h3 id="title-extra-fields" style="display: none;">Extra-Felder</h3>
        <div id="extra-fields-checkboxes" class="checkbox-grid checkbox-grid-single" style="display: none;"></div>
      </div>

      <div class="action-buttons">
        <button id="btn-print" class="fm-btn fm-btn-primary" onclick="filamanPrint()">Drucken</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline">Zurücksetzen</button>
      </div>
    </aside>

    <main class="preview-container">
      <div id="label-preview" class="label-preview">
        <!-- Top: Logo area -->
        <div id="label-top" class="label-top">
          <img id="prev-logo" class="label-logo" alt="" />
          <div id="prev-mfr-text" class="label-mfr-text"></div>
        </div>
        <div id="label-top-divider" class="label-divider"></div>

        <!-- Middle: Designation + Color swatch -->
        <div id="label-middle" class="label-middle">
          <div class="label-middle-left">
            <div id="prev-filament" class="label-designation"></div>
            <div id="prev-color-row" class="label-color-row">
              <div id="prev-color-swatch" class="label-color-swatch"></div>
              <span id="prev-color-name" class="label-color-name"></span>
            </div>
          </div>
          <div id="prev-hex-code" class="label-hex-code"></div>
        </div>

        <!-- Bottom: ID + Extra fields left, QR right -->
        <div id="label-bottom" class="label-bottom">
          <div class="label-bottom-left">
            <div id="prev-id" class="label-spool-id"></div>
            <div id="prev-extra-fields" class="label-extra-fields"></div>
          </div>
          <div id="label-qr-container" class="label-qr"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .print-page {
    display: flex;
    height: calc(100vh - 64px);
    margin: -32px;
    overflow: hidden;
  }

  .print-sidebar {
    width: 320px;
    background: var(--bg-elevated);
    border-right: 1px solid var(--border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity var(--transition);
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .settings-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .settings-section h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-muted);
    margin: 0;
  }

  .preview-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    overflow: auto;
    background: var(--bg-soft);
  }

  .label-preview {
    background: white;
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    padding: 2mm;
    box-sizing: border-box;
    overflow: hidden;
    position: relative;
    border: 1px dashed #ccc;
    border-radius: 4px;
    color: black;
    font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
  }

  /* Top: Logo area */
  .label-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2mm;
    padding-bottom: 1mm;
    min-height: 0;
  }

  .label-logo {
    max-height: 8mm;
    max-width: 60%;
    object-fit: contain;
    display: block;
  }

  .label-mfr-text {
    font-weight: 600;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: black;
  }

  .label-divider {
    border-top: 0.3mm solid black;
    margin: 0 0 1mm 0;
  }

  /* Middle: Designation + Color */
  .label-middle {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2mm;
    flex: 1;
    min-height: 0;
  }

  .label-middle-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5mm;
  }

  .label-designation {
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: black;
  }

  .label-color-row {
    display: flex;
    align-items: center;
    gap: 1.5mm;
  }

  .label-color-swatch {
    width: 100%;
    height: 3mm;
    border-radius: 0.5mm;
    flex-shrink: 0;
  }

  .label-color-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: black;
  }

  .label-hex-code {
    font-family: 'Space Mono', 'Courier New', monospace;
    white-space: nowrap;
    color: black;
    flex-shrink: 0;
    align-self: flex-end;
  }

  /* Bottom: ID + Extra fields left, QR right */
  .label-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2mm;
    margin-top: auto;
  }

  .label-bottom-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3mm;
  }

  .label-spool-id {
    font-weight: 600;
    color: black;
  }

  .label-extra-fields {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .label-qr {
    flex-shrink: 0;
  }

  .fm-label {
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 6px;
    display: block;
    color: var(--text);
  }

  .fm-input {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
    height: 42px;
    box-sizing: border-box;
  }

  .fm-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }

  .fm-checkbox-group {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: background var(--transition);
  }

  .fm-checkbox-group:hover {
    background: var(--bg-soft);
  }

  .fm-checkbox-group input {
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .fm-checkbox-group span {
    font-size: 0.9rem;
    color: var(--text);
  }

  .fm-btn {
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.2px;
    cursor: pointer;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    font-family: var(--font-sans);
  }

  .fm-btn-primary {
    background: var(--accent);
    color: var(--btn-primary-text);
    box-shadow: var(--glow);
  }

  .fm-btn-primary:hover {
    transform: translateY(-2px);
  }

  .fm-btn-outline {
    background: transparent;
    border-color: var(--border);
    color: var(--text);
  }

  .fm-btn-outline:hover {
    background: var(--bg-soft);
  }

  .action-buttons {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .checkbox-grid-single {
    grid-template-columns: 1fr;
  }
</style>

<style is:global>
  @media print {
    /* Reset page */
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    /* Hide Layout elements */
    .fm-sidebar,
    #fm-confirm-overlay,
    .fm-sidebar-backdrop {
      display: none !important;
    }

    /* Reset Layout grid to block - ensure visibility */
    .fm-page {
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      background: white !important;
      min-height: 0 !important;
      height: auto !important;
      position: static !important;
    }

    .fm-page > main {
      padding: 0 !important;
      margin: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    /* Hide print settings sidebar */
    .print-sidebar {
      display: none !important;
    }

    /* Reset print page containers */
    .print-page {
      margin: 0 !important;
      height: auto !important;
      display: block !important;
    }

    .preview-container {
      padding: 0 !important;
      margin: 0 !important;
      display: block !important;
      overflow: visible !important;
      background: white !important;
    }

    /* The label */
    .label-preview {
      box-shadow: none !important;
      border: none !important;
      border-radius: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      background: white !important;
      color: black !important;
      margin: 0 !important;
      padding: 2mm !important;
      overflow: hidden !important;
      break-inside: avoid !important;
      page-break-inside: avoid !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      /* Dimensions set dynamically via JS #page-style tag */
    }

    .label-preview div,
    .label-preview span {
      color: black !important;
    }

    .label-color-swatch {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    .label-qr {
      flex-shrink: 0 !important;
    }

    .label-qr img {
      display: block !important;
    }

    .label-logo {
      display: block !important;
    }

    @page {
      /* margin set dynamically via JS #page-style tag */
    }
  }
</style>

<script>
  // Global print function for Safari compatibility
  ;(window as any).filamanPrint = function() {
    try {
      // Try execCommand first (better Safari support)
      document.execCommand('print', false, null)
    } catch (e) {
      // Fallback to window.print
      window.print()
    }
  }

  const id = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]

  const params = new URLSearchParams(window.location.search)
  const labelData = {
    id: id,
    designation: params.get('designation') || '',
    manufacturer: params.get('mfr') || '',
    type: params.get('type') || '',
    color: params.get('color') || '',
    mfr_id: params.get('mfr_id') || '',
    hex_code: params.get('hex_code') || '',
  }

  let extraFields: {key: string, label: string, value: string, source?: string}[] = []
  try {
    const stored = sessionStorage.getItem('filaman-label-extra-fields')
    if (stored) extraFields = JSON.parse(stored)
  } catch(e) { /* ignore */ }

  // DOM references
  const widthInput = document.getElementById('input-width')
  const heightInput = document.getElementById('input-height')
  const fontSizeInput = document.getElementById('input-font-size')
  const qrSizeInput = document.getElementById('input-qr-size')
  const checkLogo = document.getElementById('check-logo') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const checkColorSwatch = document.getElementById('check-color-swatch') as HTMLInputElement
  const labelPreview = document.getElementById('label-preview')
  const qrContainer = document.getElementById('label-qr-container')

  const LABEL_SETTINGS_KEY = 'filaman-label-settings'

  // Label logo state
  let labelLogoUrl: string | null = null
  let labelLogoLoaded = false

  // Try to load the manufacturer's label-logo
  async function loadLabelLogo() {
    if (!labelData.mfr_id) return
    try {
      const resp = await fetch(`/api/v1/manufacturers/${labelData.mfr_id}/label-logo`, {
        credentials: 'include',
      })
      if (resp.ok) {
        const blob = await resp.blob()
        labelLogoUrl = URL.createObjectURL(blob)
        labelLogoLoaded = true
      }
    } catch {
      // Label logo not available — fall back to manufacturer name text
    }
  }

  // Build extra field checkboxes dynamically
  const extraFieldsTitle = document.getElementById('title-extra-fields')
  const extraFieldsCheckboxes = document.getElementById('extra-fields-checkboxes')
  const extraFieldChecks: {key: string, label: string, value: string, checkbox: HTMLInputElement}[] = []

  let savedExtraFieldSettings: Record<string, boolean> = {}
  try {
    const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
    if (saved) {
      const s = JSON.parse(saved)
      if (s.extraFields) savedExtraFieldSettings = s.extraFields
    }
  } catch(e) { /* ignore */ }

  if (extraFields.length > 0) {
    extraFieldsTitle.style.display = ''
    extraFieldsCheckboxes.style.display = ''
    const hasBothSources = extraFields.some(ef => ef.source === 'spool') && extraFields.some(ef => ef.source === 'filament')

    // Copy Astro scoped-style attribute from existing checkboxes so dynamic elements get the same styles
    const scopeAttr = (() => {
      const existing = document.querySelector('.fm-checkbox-group')
      if (!existing) return null
      return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
    })()

    for (const ef of extraFields) {
      const lbl = document.createElement('label')
      lbl.className = 'fm-checkbox-group'
      const cb = document.createElement('input')
      cb.type = 'checkbox'
      cb.id = `check-ef-${ef.key}`
      cb.checked = savedExtraFieldSettings[ef.key] || false
      const span = document.createElement('span')
      span.textContent = hasBothSources ? `${ef.label} (${ef.source === 'spool' ? ((window as any).__t('dashboard.spool') || 'Spool') : ((window as any).__t('spools.filament') || 'Filament')})` : ef.label
      if (scopeAttr) {
        lbl.setAttribute(scopeAttr.name, '')
        cb.setAttribute(scopeAttr.name, '')
        span.setAttribute(scopeAttr.name, '')
      }
      lbl.appendChild(cb)
      lbl.appendChild(span)
      extraFieldsCheckboxes.appendChild(lbl)
      extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
      cb.addEventListener('change', updatePreview)
    }
  }

  function saveSettings() {
    const settings: Record<string, any> = {
      width: (widthInput as HTMLInputElement).value,
      height: (heightInput as HTMLInputElement).value,
      fontSize: (fontSizeInput as HTMLInputElement).value,
      qrSize: (qrSizeInput as HTMLInputElement).value,
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      extraFields: extraFieldChecks.reduce((acc, ef) => {
        acc[ef.key] = ef.checkbox.checked
        return acc
      }, {} as Record<string, boolean>)
    }
    localStorage.setItem(LABEL_SETTINGS_KEY, JSON.stringify(settings))
  }

  function loadSettings() {
    try {
      const saved = localStorage.getItem(LABEL_SETTINGS_KEY)
      if (!saved) return
      const s = JSON.parse(saved)
      if (s.width) (widthInput as HTMLInputElement).value = s.width
      if (s.height) (heightInput as HTMLInputElement).value = s.height
      if (s.fontSize) (fontSizeInput as HTMLInputElement).value = s.fontSize
      if (s.qrSize) (qrSizeInput as HTMLInputElement).value = s.qrSize
      if (s.showLogo !== undefined) checkLogo.checked = s.showLogo
      if (s.showQR !== undefined) checkQR.checked = s.showQR
      if (s.showID !== undefined) checkID.checked = s.showID
      if (s.showMfr !== undefined) checkMfr.checked = s.showMfr
      if (s.showMat !== undefined) checkMat.checked = s.showMat
      if (s.showColor !== undefined) checkColor.checked = s.showColor
      if (s.showColorSwatch !== undefined) checkColorSwatch.checked = s.showColorSwatch
    } catch (e) { /* ignore corrupt data */ }
  }

  loadSettings()

  document.getElementById('title-settings').textContent = (window as any).__t('spools.printSettings')
  document.getElementById('label-width-text').textContent = (window as any).__t('spools.labelWidth')
  document.getElementById('label-height-text').textContent = (window as any).__t('spools.labelHeight')
  document.getElementById('label-font-size-text').textContent = (window as any).__t('spools.fontSize')
  document.getElementById('label-qr-size-text').textContent = (window as any).__t('spools.qrSize')
  document.getElementById('label-show-logo').textContent = (window as any).__t('spools.showLogo') || 'Logo'
  document.getElementById('label-show-qr').textContent = (window as any).__t('spools.showQRCode')
  document.getElementById('label-show-id').textContent = (window as any).__t('spools.showSpoolId')
  document.getElementById('label-show-mfr').textContent = (window as any).__t('spools.showManufacturer')
  document.getElementById('label-show-mat').textContent = (window as any).__t('spools.showMaterial')
  document.getElementById('label-show-color').textContent = (window as any).__t('spools.showColor')
  document.getElementById('label-show-color-swatch').textContent = (window as any).__t('spools.showColorSwatch') || 'Farbbalken'
  if (extraFields.length > 0) {
    document.getElementById('title-extra-fields').textContent = (window as any).__t('spools.extraFieldsLabel')
  }
  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  backBtn.href = `/spools/${id}`
  document.getElementById('label-back').textContent = (window as any).__t('spools.backToSpool')
  document.getElementById('btn-print').textContent = (window as any).__t('common.print')
  document.getElementById('btn-reset').textContent = (window as any).__t('spools.resetDefaults')

  async function updatePreview() {
    if (typeof (window as any).QRCode === 'undefined') {
      await new Promise((resolve, reject) => {
        const script = document.createElement('script')
        script.src = '/vendor/qrcode.min.js'
        script.onload = resolve
        script.onerror = reject
        document.head.appendChild(script)
      })
    }

    const w = (widthInput as HTMLInputElement).value
    const h = (heightInput as HTMLInputElement).value
    const qrSize = (qrSizeInput as HTMLInputElement).value
    const fontSizeBase = parseInt((fontSizeInput as HTMLInputElement).value) / 100

    labelPreview.style.width = w + 'mm'
    labelPreview.style.height = h + 'mm'

    // === TOP: Logo / Manufacturer ===
    const topArea = document.getElementById('label-top')
    const topDivider = document.getElementById('label-top-divider')
    const logoImg = document.getElementById('prev-logo') as HTMLImageElement
    const mfrTextEl = document.getElementById('prev-mfr-text')

    const showLogo = checkLogo.checked
    const showMfr = checkMfr.checked

    if (showLogo && labelLogoLoaded && labelLogoUrl) {
      logoImg.src = labelLogoUrl
      logoImg.style.display = 'block'
      logoImg.style.maxHeight = (fontSizeBase * 8) + 'mm'
      mfrTextEl.style.display = 'none'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else if (showLogo && showMfr && labelData.manufacturer) {
      // No logo available — show manufacturer name as text in top area
      logoImg.style.display = 'none'
      mfrTextEl.textContent = labelData.manufacturer
      mfrTextEl.style.display = 'block'
      mfrTextEl.style.fontSize = (fontSizeBase * 11) + 'pt'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else if (showMfr && labelData.manufacturer) {
      logoImg.style.display = 'none'
      mfrTextEl.textContent = labelData.manufacturer
      mfrTextEl.style.display = 'block'
      mfrTextEl.style.fontSize = (fontSizeBase * 11) + 'pt'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else {
      topArea.style.display = 'none'
      topDivider.style.display = 'none'
    }

    // === MIDDLE: Designation + Color ===
    const filamentEl = document.getElementById('prev-filament')
    const matText = checkMat.checked ? labelData.type : ''
    const desigText = labelData.designation || ''
    const fullDesig = [desigText, matText].filter(Boolean).join(' ')
    filamentEl.textContent = fullDesig
    filamentEl.style.fontSize = (fontSizeBase * 12) + 'pt'
    filamentEl.style.display = fullDesig ? 'block' : 'none'

    // Color row: swatch + name
    const colorRow = document.getElementById('prev-color-row')
    const colorSwatch = document.getElementById('prev-color-swatch')
    const colorName = document.getElementById('prev-color-name')
    const hexCodeEl = document.getElementById('prev-hex-code')

    const showColor = checkColor.checked
    const showSwatch = checkColorSwatch.checked
    const hasHex = !!labelData.hex_code

    if (showSwatch && hasHex) {
      colorSwatch.style.display = 'block'
      colorSwatch.style.backgroundColor = labelData.hex_code.startsWith('#') ? labelData.hex_code : `#${labelData.hex_code}`
    } else {
      colorSwatch.style.display = 'none'
    }

    if (showColor && labelData.color) {
      colorName.textContent = labelData.color
      colorName.style.display = 'inline'
      colorName.style.fontSize = (fontSizeBase * 10) + 'pt'
    } else {
      colorName.style.display = 'none'
    }

    colorRow.style.display = (showColor || showSwatch) ? 'flex' : 'none'

    if (hasHex && (showColor || showSwatch)) {
      const hexStr = labelData.hex_code.startsWith('#') ? labelData.hex_code.toUpperCase() : `#${labelData.hex_code.toUpperCase()}`
      hexCodeEl.textContent = hexStr
      hexCodeEl.style.display = 'block'
      hexCodeEl.style.fontSize = (fontSizeBase * 9) + 'pt'
    } else {
      hexCodeEl.style.display = 'none'
    }

    // === BOTTOM: ID + Extra fields + QR ===
    const idEl = document.getElementById('prev-id')
    if (checkID.checked) {
      idEl.textContent = `#${labelData.id}`
      idEl.style.display = 'block'
      idEl.style.fontSize = (fontSizeBase * 7.5) + 'pt'
    } else {
      idEl.style.display = 'none'
    }

    // Extra fields
    const extraContainer = document.getElementById('prev-extra-fields')
    extraContainer.innerHTML = ''
    for (const ef of extraFieldChecks) {
      if (ef.checkbox.checked) {
        const div = document.createElement('div')
        div.style.fontSize = (fontSizeBase * 7) + 'pt'
        div.style.color = 'black'
        div.style.whiteSpace = 'nowrap'
        div.style.overflow = 'hidden'
        div.style.textOverflow = 'ellipsis'
        div.style.lineHeight = '1.3'
        div.innerHTML = `<span style="color:#555">${ef.label}:</span> ${ef.value}`
        extraContainer.appendChild(div)
      }
    }

    // QR Code
    qrContainer.style.display = checkQR.checked ? 'block' : 'none'
    if (checkQR.checked) {
      qrContainer.innerHTML = ''
      const url = window.location.origin + '/spools/' + labelData.id
      const qrPx = Math.round(parseInt(qrSize) * 3.78)

      // @ts-ignore
      new QRCode(qrContainer, {
        text: url,
        width: qrPx,
        height: qrPx,
        colorDark: "#000000",
        colorLight: "#ffffff",
        correctLevel: (window as any).QRCode.CorrectLevel.H
      })

      qrContainer.style.width = qrSize + 'mm'
      qrContainer.style.height = qrSize + 'mm'

      // Draw "FilaMan" text in center of QR code, then convert to img for print
      const canvas = qrContainer.querySelector('canvas')
      if (canvas) {
        const ctx = (canvas as HTMLCanvasElement).getContext('2d')
        if (ctx) {
          const fontSize = Math.round(qrPx * 0.13)
          ctx.font = `700 ${fontSize}px "Space Grotesk", sans-serif`
          ctx.textAlign = 'center'
          ctx.textBaseline = 'middle'
          const text = 'FilaMan'
          const metrics = ctx.measureText(text)
          const tw = metrics.width
          const th = fontSize
          const pad = Math.round(fontSize * 0.3)
          const cx = qrPx / 2, cy = qrPx / 2

          // White background behind text
          ctx.fillStyle = '#ffffff'
          ctx.fillRect(cx - tw / 2 - pad, cy - th / 2 - pad, tw + pad * 2, th + pad * 2)

          // Draw text
          ctx.fillStyle = '#000000'
          ctx.fillText(text, cx, cy)
        }

        const dataUrl = (canvas as HTMLCanvasElement).toDataURL('image/png')
        qrContainer.innerHTML = ''
        const img = document.createElement('img')
        img.src = dataUrl
        img.style.width = '100%'
        img.style.height = '100%'
        img.style.display = 'block'
        qrContainer.appendChild(img)
      }

      qrContainer.style.flexShrink = '0'
    }

    // Print styles
    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    const style = document.createElement('style')
    // Safari doesn't support @page { size } — use default page margins so label stays in printable area
    // Chrome/Edge support @page { size } — set exact label dimensions with no margin
    const pageRule = isSafari
      ? ''
      : `@page { size: ${w}mm ${h}mm; margin: 0; }`
    style.innerHTML = `
      ${pageRule}
      @media print {
        .label-preview {
          width: ${w}mm !important;
          height: ${h}mm !important;
          min-width: ${w}mm !important;
          min-height: ${h}mm !important;
          max-width: ${w}mm !important;
          max-height: ${h}mm !important;
        }
      }
    `
    const oldStyle = document.querySelector('style#page-style')
    if (oldStyle) oldStyle.remove()
    style.id = 'page-style'
    document.head.appendChild(style)
    saveSettings()
  }

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkLogo, checkQR, checkID, checkMfr, checkMat, checkColor, checkColorSwatch].forEach(el => {
    el.addEventListener('change', updatePreview)
    if ((el as HTMLInputElement).type === 'range' || (el as HTMLInputElement).type === 'number') {
      el.addEventListener('input', updatePreview)
    }
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(LABEL_SETTINGS_KEY);
    (widthInput as HTMLInputElement).value = '60';
    (heightInput as HTMLInputElement).value = '40';
    (fontSizeInput as HTMLInputElement).value = '100';
    (qrSizeInput as HTMLInputElement).value = '18';
    checkLogo.checked = true;
    checkQR.checked = true;
    checkID.checked = true;
    checkMfr.checked = true;
    checkMat.checked = true;
    checkColor.checked = true;
    checkColorSwatch.checked = true;
    for (const ef of extraFieldChecks) {
      ef.checkbox.checked = false
    }
    updatePreview()
  })

  // Initialize: load logo then render
  loadLabelLogo().then(() => updatePreview())
</script>
