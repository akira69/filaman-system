---
import Layout from '../../layouts/Layout.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}

const { id } = Astro.params
---

<Layout title="FilaMan - Printer">
  <div style="margin-bottom: 24px;">
    <a href="/printers" style="color: var(--accent); text-decoration: none;">&larr; <span data-i18n="printers.backToPrinters">Back to Printers</span></a>
  </div>
  
  <div id="printer-content">
    <p style="color: var(--text-muted);" data-i18n="common.loading">Loading...</p>
  </div>
  
  <script>
    import { t, initI18n, getLang } from '../../lib/i18n'
    import { getAbortSignal, isAbortError } from '../../lib/abort'
    await initI18n()

    const id = window.location.pathname.split('/').filter(Boolean).pop()!
    if (id === 'detail') {
      window.location.href = '/printers'
    }

    let printer: any = null
    let pluginSchema: any = null
    let editingConfig = false
    let driverHealth: any = null
    let debugOpen = false
    let debugLog: any[] = []
    let debugPollTimer: number | null = null
    let healthPollTimer: number | null = null
    let lastDebugTs: string | null = null
    
    function getCsrfToken(): string {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    function escapeHtml(str: string): string {
      const d = document.createElement('div')
      d.textContent = str
      return d.innerHTML
    }
    
    async function loadPrinter() {
      try {
        const response = await fetch(`/api/v1/printers/${id}`, { credentials: 'include', signal: getAbortSignal() })
        
        if (!response.ok) {
          if (response.status === 404) {
            document.getElementById('printer-content')!.innerHTML = `<div style="color: var(--error-text);">${t('printers.notFound')}</div>`
            return
          }
          throw new Error('Failed to fetch printer')
        }
        
        printer = await response.json()
        await loadPluginSchema()
        await loadDriverHealth()
        renderPrinter()
        startHealthPolling()
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load printer:', error)
        document.getElementById('printer-content')!.innerHTML = `<div style="color: var(--error-text);">${t('printers.failedLoadSingle')}</div>`
      }
    }

    async function loadPluginSchema() {
      try {
        const response = await fetch('/api/v1/admin/system/plugins', { credentials: 'include', signal: getAbortSignal() })
        if (!response.ok) return
        const plugins = await response.json()
        const plugin = plugins.find((p: any) => p.driver_key === printer.driver_key)
        pluginSchema = plugin?.config_schema || null
      } catch {
        pluginSchema = null
      }
    }

    function renderConfigView(): string {
      const config = printer.driver_config
      if (!pluginSchema?.properties || !config || Object.keys(config).length === 0) {
        return `<p style="color: var(--text-muted); font-size: 0.9rem;">${t('printers.noConfig')}</p>`
      }

      const props = pluginSchema.properties as Record<string, any>
      let html = '<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">'
      
      for (const [key, prop] of Object.entries(props)) {
        const value = config[key]
        if (value === undefined || value === null) continue
        const label = escapeHtml((prop as any).title || key)
        const isSecret = key.toLowerCase().includes('code') || key.toLowerCase().includes('password') || key.toLowerCase().includes('secret') || key.toLowerCase().includes('token')
        let displayValue = isSecret ? '••••••••' : escapeHtml(String(value))
        // Enum: Display-Name statt interner Wert anzeigen
        const p = prop as any
        if (p.enum && Array.isArray(p.enum) && p.enumNames) {
          const idx = p.enum.indexOf(value)
          if (idx >= 0 && p.enumNames[idx]) displayValue = escapeHtml(String(p.enumNames[idx]))
        }
        html += `
          <div>
            <div style="font-size: 0.8rem; color: var(--text-muted);">${label}</div>
            <div style="font-size: 1rem; font-weight: 500; margin-top: 2px;">${displayValue}</div>
          </div>`
      }
      
      html += '</div>'
      return html
    }

    function renderConfigEdit(): string {
      if (!pluginSchema?.properties) return ''

      const props = pluginSchema.properties as Record<string, any>
      const required: string[] = pluginSchema.required || []
      const config = printer.driver_config || {}
      let html = '<form id="config-form" style="display: grid; gap: 12px; max-width: 480px;">'

      for (const [key, prop] of Object.entries(props)) {
        const p = prop as any
        const isRequired = required.includes(key)
        const value = config[key] ?? p.default ?? ''
        const label = escapeHtml(p.title || key) + (isRequired ? ' *' : '')
        
        html += `<div>`
        html += `<label class="fm-label" for="config-${key}">${label}</label>`

        if (p.enum && Array.isArray(p.enum)) {
          const enumNames: string[] = p.enumNames || p.enum
          const options = p.enum.map((val: string, i: number) => {
            const selected = String(val) === String(value) ? ' selected' : ''
            return `<option value="${escapeHtml(String(val))}"${selected}>${escapeHtml(String(enumNames[i] ?? val))}</option>`
          }).join('')
          html += `<select class="fm-input" id="config-${key}" name="${key}"${isRequired ? ' required' : ''}>${options}</select>`
        } else if (p.type === 'integer' || p.type === 'number') {
          html += `<input class="fm-input" id="config-${key}" name="${key}" type="number" value="${escapeHtml(String(value))}"${p.minimum !== undefined ? ` min="${p.minimum}"` : ''}${p.maximum !== undefined ? ` max="${p.maximum}"` : ''}${isRequired ? ' required' : ''}>`
        } else {
          html += `<input class="fm-input" id="config-${key}" name="${key}" type="text" value="${escapeHtml(String(value))}"${isRequired ? ' required' : ''}>`
        }

        if (p.description) {
          html += `<div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">${escapeHtml(p.description)}</div>`
        }
        html += '</div>'
      }

      html += `
        <div style="display: flex; gap: 8px; align-items: center; margin-top: 8px;">
          <button type="submit" class="fm-btn fm-btn-primary">${t('common.save')}</button>
          <button type="button" id="btn-cancel-config" class="fm-btn fm-btn-outline">${t('common.cancel')}</button>
          <span id="config-save-msg" class="hidden" style="font-size: 0.85rem;"></span>
        </div>
      </form>`
      return html
    }

    function showConfigMessage(text: string, isError: boolean) {
      const msg = document.getElementById('config-save-msg')
      if (!msg) return
      msg.textContent = text
      msg.style.color = isError ? 'var(--error-text)' : 'var(--success-text)'
      msg.classList.remove('hidden')
      setTimeout(() => msg.classList.add('hidden'), 3000)
    }
    
    function renderPrinter() {
      const container = document.getElementById('printer-content')!

      let configSection = ''
      if (pluginSchema?.properties) {
        configSection = `
          <div class="fm-card" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <h2 style="font-size: 1.2rem; font-weight: 600;">${t('printers.configuration')}</h2>
              <button id="btn-edit-config" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('printers.editConfig')}</button>
            </div>
            <div id="config-content">
              ${editingConfig ? renderConfigEdit() : renderConfigView()}
            </div>
          </div>`
      }

      let paramsSection = ''
      if (printer.driver_key) {
        paramsSection = `
          <div class="fm-card" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <h2 style="font-size: 1.2rem; font-weight: 600;">${t('printers.printerParameters')}</h2>
              <div style="display: flex; gap: 8px;">
                <button id="btn-export-params" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('printers.exportParams')}</button>
                <label id="btn-import-params" class="fm-btn fm-btn-outline" style="font-size: 0.85rem; cursor: pointer;">
                  ${t('printers.importParams')}
                  <input type="file" accept=".json" id="import-params-file" style="display: none;" />
                </label>
              </div>
            </div>
            <p style="font-size: 0.85rem; color: var(--text-muted);">${t('printers.paramsManagement')}</p>
          </div>`
      }

      let slotsSection = ''
      if (printer.slots && printer.slots.length > 0) {
        const slotItems = printer.slots
          .sort((a: any, b: any) => a.slot_no - b.slot_no)
          .map((s: any) => {
            const a = s.assignment
            const isExt = s.slot_no >= 1000
            const slotLabel = escapeHtml(s.name || (isExt ? t('printers.externalSlot') : t('printers.slotLabel').replace('{no}', s.slot_no)))

            // Color indicator from assignment
            let colorDot = ''
            let colorHex = a?.color_hex || a?.tray_color || ''
            // Normalize: add # prefix, strip alpha channel if 8-char hex
            if (colorHex && !colorHex.startsWith('#')) colorHex = '#' + colorHex
            if (colorHex.length === 9) colorHex = colorHex.slice(0, 7) // strip alpha
            if (colorHex.length >= 7) {
              colorDot = `<span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:${colorHex};border:1px solid var(--border);flex-shrink:0;"></span>`
            }

            // Occupied info
            let occupiedHtml = ''
            if (a && a.present) {
              if (a.spool_id && a.spool_name) {
                occupiedHtml = `
                  <div style="display:flex;align-items:center;gap:6px;margin-top:6px;">
                    ${colorDot}
                    <a href="/spools/${a.spool_id}" style="color:var(--accent);text-decoration:none;font-size:0.85rem;font-weight:500;" onclick="event.stopPropagation()">${escapeHtml(a.spool_name)}</a>
                  </div>
                  <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px;">${escapeHtml(a.material_type || '')}</div>`
              } else {
                const trayMaterial = a.tray_type ? escapeHtml(a.tray_type) : t('printers.unknownFilament')
                occupiedHtml = `
                  <div style="display:flex;align-items:center;gap:6px;margin-top:6px;">
                    ${colorDot}
                    <span style="font-size:0.85rem;color:var(--text-muted);font-style:italic;">${trayMaterial}</span>
                  </div>`
              }
            } else {
              occupiedHtml = `<div style="font-size:0.85rem;color:var(--text-muted);margin-top:6px;">${t('printers.slotEmpty')}</div>`
            }

            // Status badge
            const presentBadge = a?.present
              ? `<span style="padding:2px 8px;font-size:0.7rem;border-radius:999px;background:var(--bg-soft);color:#22c55e;">${t('printers.slotOccupied')}</span>`
              : `<span style="padding:2px 8px;font-size:0.7rem;border-radius:999px;background:var(--bg-soft);color:var(--text-muted);">${t('printers.slotEmpty')}</span>`

            // Tray details (meta fields)
            let trayDetailsHtml = ''
            if (a && a.present) {
              const details: string[] = []
              if (a.tray_info_idx) details.push(`<span title="Tray Info Index">Tray Info: ${escapeHtml(a.tray_info_idx)}</span>`)
              if (a.setting_id) details.push(`<span title="Setting ID">Setting: ${escapeHtml(a.setting_id)}</span>`)
              if (a.cali_idx != null) details.push(`<span title="Calibration Index">Cali: ${a.cali_idx}</span>`)
              if (a.nozzle_temp_min != null || a.nozzle_temp_max != null) {
                const min = a.nozzle_temp_min ?? '?'
                const max = a.nozzle_temp_max ?? '?'
                details.push(`<span title="Nozzle Temperature Range">Nozzle: ${min}\u2013${max}\u00B0C</span>`)
              }
              if (details.length > 0) {
                trayDetailsHtml = `<div style="display:flex;gap:10px;flex-wrap:wrap;font-size:0.7rem;color:var(--text-muted);margin-top:4px;">${details.join('<span style="opacity:0.3;">|</span>')}</div>`
              }
            }

            return `
              <div class="fm-card" style="padding:12px 14px;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div style="font-weight:600;font-size:0.95rem;">${slotLabel}</div>
                  ${presentBadge}
                </div>
                ${occupiedHtml}
                ${trayDetailsHtml}
              </div>`
          })
          .join('')

        slotsSection = `
          <div style="margin-top: 24px;">
            <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 12px;">${t('printers.slots').replace('{count}', printer.slots.length)}</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
              ${slotItems}
            </div>
          </div>`
      }

      // Connection status section
      let connectionSection = ''
      if (printer.driver_key) {
        let statusDot = ''
        let statusText = ''
        if (!driverHealth || !driverHealth.running) {
          statusDot = 'background: var(--text-muted);'
          statusText = t('printers.driverNotRunning')
        } else if (driverHealth.connected) {
          statusDot = 'background: #22c55e;'
          statusText = t('printers.connected')
        } else {
          statusDot = 'background: var(--error-text);'
          statusText = t('printers.disconnected')
        }
        const isRunning = driverHealth?.running
        const startStopBtn = isRunning
          ? `<button id="btn-driver-toggle" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('printers.stopDriver')}</button>`
          : `<button id="btn-driver-toggle" class="fm-btn fm-btn-primary" style="font-size: 0.85rem;">${t('printers.startDriver')}</button>`
        connectionSection = `
          <div class="fm-card" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <div style="display: flex; align-items: center; gap: 8px;">
                <span id="health-dot" style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; ${statusDot}"></span>
                <span id="health-text" style="font-weight: 600;">${statusText}</span>
              </div>
              <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                ${startStopBtn}
                <button id="btn-debug-console" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('printers.debugConsole')}</button>
                ${isRunning ? (driverHealth?.sync_actions || []).map((a: any) => {
                  const label = getLang() === 'de' ? (a.label_de || a.label) : a.label
                  const variant = a.variant === 'danger' ? 'fm-btn-danger' : 'fm-btn-outline'
                  return `<button class="fm-btn ${variant} btn-sync-action" data-action="${escapeHtml(a.action)}" style="font-size: 0.85rem;">${escapeHtml(label)}</button>`
                }).join('') : ''}
              </div>
            </div>
            ${driverHealth?.running && driverHealth?.connected ? `
              <div id="health-summary" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;">
                ${driverHealth.printer_model || driverHealth.external_spool ? `<span style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:var(--bg-soft);border-radius:999px;font-size:0.8rem;color:var(--text-muted);">${driverHealth.printer_model ? escapeHtml(driverHealth.printer_model) : ''}${driverHealth.printer_model && driverHealth.external_spool ? ' · ' : ''}${driverHealth.external_spool ? '1 ext. Slot' : ''}</span>` : ''}
                ${(driverHealth.ams_units || []).map((u: any) => {
                  const amsLabel = (driverHealth.ams_type === 'AMS Lite') ? 'AMS Lite' : ('AMS ' + (u.ams_id + 1))
                  const parts = [amsLabel, u.tray_count + ' Slots']
                  if (u.serial) parts.push('SN: ' + u.serial)
                  return '<span style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:var(--bg-soft);border-radius:999px;font-size:0.8rem;color:var(--text-muted);">' + parts.join(' · ') + '</span>'
                }).join('')}
              </div>
            ` : ''}
          </div>`
      }


      // AMS-Einheiten Section
      let amsSection = ''
      if (driverHealth?.running && driverHealth?.connected && driverHealth?.ams_units?.length > 0) {
        const amsType = driverHealth.ams_type || 'AMS'
        const amsItems = driverHealth.ams_units.map((ams: any) => {
          const humidity = ams.humidity != null ? `${ams.humidity}%` : '\u2014'
          const temp = ams.temp != null ? `${ams.temp}\u00b0C` : '\u2014'
          const amsLabel = amsType === 'AMS Lite' ? 'AMS Lite' : `${amsType} ${ams.ams_id + 1}`
          return `
            <div class="fm-card" style="padding: 12px 16px;">
              <div style="font-weight: 600; font-size: 0.95rem;">${amsLabel}</div>
              ${ams.serial ? `<div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">SN: ${escapeHtml(ams.serial)}</div>` : ''}
              <div style="display: flex; gap: 14px; margin-top: 8px; font-size: 0.8rem; color: var(--text-muted);">
                <span style="display:inline-flex;align-items:center;gap:4px;"><img src="/slots.svg" alt="" style="width:14px;height:14px;opacity:0.6;">${ams.tray_count} Slots</span>
                <span style="display:inline-flex;align-items:center;gap:4px;"><img src="/moisture.svg" alt="" style="width:14px;height:14px;opacity:0.6;">${humidity}</span>
                <span style="display:inline-flex;align-items:center;gap:4px;"><img src="/temperature.svg" alt="" style="width:14px;height:14px;opacity:0.6;">${temp}</span>
              </div>
            </div>`
        }).join('')
        amsSection = `
          <div style="margin-top: 24px;">
            <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 12px;">${amsType} (${driverHealth.ams_units.length})</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
              ${amsItems}
            </div>
          </div>`
      }
      // Debug console section (hidden by default)
      let debugConsoleSection = ''
      if (debugOpen) {
        const logHtml = debugLog.length === 0
          ? `<div style="color: var(--text-muted); padding: 16px; text-align: center;">${t('printers.noDebugMessages')}</div>`
          : debugLog.map(entry => {
              const dirLabel = entry.dir === 'in' ? t('printers.incoming') : t('printers.outgoing')
              const dirColor = entry.dir === 'in' ? 'var(--accent-2)' : 'var(--accent)'
              const payloadStr = typeof entry.payload === 'object' ? JSON.stringify(entry.payload, null, 2) : String(entry.payload)
              return `<div style="border-bottom: 1px solid var(--border); padding: 6px 8px; font-size: 0.8rem;">
                <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 4px;">
                  <span style="color: ${dirColor}; font-weight: 700; font-size: 0.7rem; padding: 1px 6px; border-radius: 4px; background: var(--bg-soft);">${dirLabel}</span>
                  <span style="color: var(--text-muted); font-size: 0.7rem;">${escapeHtml(entry.ts)}</span>
                  <span style="color: var(--text-muted); font-size: 0.7rem; flex: 1;">${escapeHtml(entry.topic)}</span>
                  <button class="btn-copy-debug" style="background:none;border:1px solid var(--border);border-radius:4px;color:var(--text-muted);cursor:pointer;font-size:0.75rem;padding:2px 6px;line-height:1;flex-shrink:0;" title="Copy">&#x29C9;</button>
                </div>
                <pre style="margin: 0; white-space: pre-wrap; word-break: break-all; font-size: 0.75rem; color: var(--text); max-height: 200px; overflow-y: auto;">${escapeHtml(payloadStr)}</pre>
              </div>`
            }).join('')

        debugConsoleSection = `
          <div class="fm-card" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <h2 style="font-size: 1.2rem; font-weight: 600;">${t('printers.debugConsoleTitle')}</h2>
              <div style="display: flex; gap: 8px;">
                <button id="btn-clear-debug" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('printers.clearLog')}</button>
                <button id="btn-close-debug" class="fm-btn fm-btn-outline" style="font-size: 0.85rem;">${t('common.close')}</button>
              </div>
            </div>
            <div id="debug-log-container" style="background: var(--bg-deep, var(--bg-soft)); border-radius: 8px; max-height: 400px; overflow-y: auto; font-family: monospace;">
              ${logHtml}
            </div>
          </div>`
      }

      container.innerHTML = `
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
          <div>
            <h1 style="font-size: 1.8rem; font-weight: 700; font-family: var(--font-serif);">${escapeHtml(printer.name)}</h1>
          </div>
          <div style="display: flex; gap: 8px;">
            <button id="btn-toggle-active" class="${printer.is_active ? 'fm-btn fm-btn-outline' : 'fm-btn fm-btn-primary'}">
              ${printer.is_active ? t('printers.deactivate') : t('printers.activate')}
            </button>
            <button id="btn-delete" class="fm-btn fm-btn-danger">
              ${t('common.delete')}
            </button>
          </div>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px;">
          <div class="fm-card">
            <div style="font-size: 0.85rem; color: var(--text-muted);">${t('printers.driver')}</div>
            <div style="font-size: 1.15rem; font-weight: 600; margin-top: 4px;">${escapeHtml(printer.driver_key)}</div>
          </div>
          <div class="fm-card">
            <div style="font-size: 0.85rem; color: var(--text-muted);">${t('common.status')}</div>
            <div style="font-size: 1.15rem; font-weight: 600; margin-top: 4px;">
              <span style="padding: 2px 8px; font-size: 0.75rem; border-radius: 999px; background: var(--bg-soft); ${printer.is_active ? 'color: var(--accent-2);' : 'color: var(--error-text);'}">
                ${printer.is_active ? t('common.active') : t('common.inactive')}
              </span>
            </div>
          </div>
        </div>

        ${configSection}
        ${paramsSection}
        ${connectionSection}
        ${amsSection}
        ${slotsSection}
        ${debugConsoleSection}
      `
      
      bindActions()
    }

    function bindActions() {
      document.getElementById('btn-delete')?.addEventListener('click', async () => {
        const result = await (window as any).__fmConfirm(t('printers.confirmDelete'), {
          checkbox: { label: t('printers.confirmDeleteParams') },
        })
        if (!result || !result.confirmed) return
        const qs = result.checked ? '?delete_params=true' : ''
        
        try {
          const response = await fetch(`/api/v1/printers/${id}${qs}`, {
            method: 'DELETE',
            headers: { 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
          })
          
          if (response.ok) {
            window.location.href = '/printers'
          } else {
            await (window as any).__fmAlert(t('printers.failedDelete'))
          }
        } catch {
          await (window as any).__fmAlert(t('printers.failedDelete'))
        }
      })
      
      document.getElementById('btn-toggle-active')?.addEventListener('click', async () => {
        try {
          const response = await fetch(`/api/v1/printers/${id}`, {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': getCsrfToken(),
            },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ is_active: !printer.is_active }),
          })
          
          if (response.ok) {
            loadPrinter()
          } else {
            await (window as any).__fmAlert(t('printers.failedUpdate'))
          }
        } catch {
          await (window as any).__fmAlert(t('printers.failedUpdate'))
        }
      })

      document.getElementById('btn-edit-config')?.addEventListener('click', () => {
        editingConfig = !editingConfig
        const configContent = document.getElementById('config-content')!
        if (editingConfig) {
          configContent.innerHTML = renderConfigEdit()
          bindConfigForm()
        } else {
          configContent.innerHTML = renderConfigView()
        }
      })

      if (editingConfig) {
        bindConfigForm()
      }

      // Driver start/stop button
      document.getElementById('btn-driver-toggle')?.addEventListener('click', async () => {
        const btn = document.getElementById('btn-driver-toggle') as HTMLButtonElement
        const isRunning = driverHealth?.running
        const endpoint = isRunning ? 'stop' : 'start'

        btn.disabled = true
        btn.textContent = isRunning ? t('printers.driverStopping') : t('printers.driverStarting')

        try {
          const response = await fetch(`/api/v1/printers/${id}/driver/${endpoint}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
          })

          if (!response.ok) {
            const data = await response.json().catch(() => ({}))
            throw new Error(data.detail?.message || 'Failed')
          }

          // Give driver a moment to connect, then refresh
          await new Promise(r => setTimeout(r, 1000))
          await loadDriverHealth()
          renderPrinter()
        } catch (err: any) {
          if (isAbortError(err)) return
          await (window as any).__fmAlert(err.message || t('printers.failedUpdate'))
          btn.disabled = false
        }
      })

      // Debug console button
      document.getElementById('btn-debug-console')?.addEventListener('click', async () => {
        debugOpen = true
        lastDebugTs = null
        debugLog = []
        try {
          await fetch(`/api/v1/printers/${id}/driver/action`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ action: 'enable_debug_log', params: {} }),
          })
        } catch { /* ignore */ }
        renderPrinter()
        startDebugPolling()
      })

      document.getElementById('btn-close-debug')?.addEventListener('click', async () => {
        debugOpen = false
        stopDebugPolling()
        try {
          await fetch(`/api/v1/printers/${id}/driver/action`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ action: 'disable_debug_log', params: {} }),
          })
        } catch { /* ignore */ }
        renderPrinter()
      })

      document.getElementById('btn-clear-debug')?.addEventListener('click', async () => {
        try {
          await fetch(`/api/v1/printers/${id}/driver/action`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ action: 'clear_debug_log', params: {} }),
          })
        } catch { /* ignore */ }
        debugLog = []
        lastDebugTs = null
        renderPrinter()
      })

      // Copy button delegation for debug log entries
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.btn-copy-debug') as HTMLButtonElement
        if (!btn) return
        const pre = btn.closest('div')?.nextElementSibling as HTMLElement
        if (!pre) return
        navigator.clipboard.writeText(pre.textContent || '').then(() => {
          btn.textContent = '\u2713'
          setTimeout(() => btn.innerHTML = '&#x29C9;', 1000)
        })
      })

      // Sync-Action button delegation (generisch aus health.sync_actions)
      document.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest('.btn-sync-action') as HTMLButtonElement
        if (!btn) return
        const action = btn.dataset.action
        if (!action) return
        btn.disabled = true
        const originalText = btn.textContent || ''
        btn.textContent = getLang() === 'de' ? 'Läuft…' : 'Running…'
        try {
          const res = await fetch(`/api/v1/printers/${id}/driver/action`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ action, params: {} }),
          })
          if (!res.ok) {
            const d = await res.json().catch(() => ({}))
            throw new Error(d.detail?.message || 'Failed')
          }
          await loadDriverHealth()
          renderPrinter()
        } catch (err: any) {
          if (isAbortError(err)) return
          await (window as any).__fmAlert(err.message || t('printers.failedUpdate'))
        } finally {
          btn.disabled = false
          btn.textContent = originalText
        }
      })

      // Export params button
      document.getElementById('btn-export-params')?.addEventListener('click', async () => {
        try {
          const response = await fetch(`/api/v1/printers/${id}/params/export`, { credentials: 'include', signal: getAbortSignal() })
          if (!response.ok) throw new Error('Failed')
          const data = await response.json()
          const hasData = (data.filament_params && Object.keys(data.filament_params).length > 0) || (data.spool_params && Object.keys(data.spool_params).length > 0)
          if (!hasData) {
            await (window as any).__fmAlert(t('printers.noParamsToExport'))
            return
          }
          const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' })
          const url = URL.createObjectURL(blob)
          const a = document.createElement('a')
          a.href = url
          a.download = `printer-params-${printer.name.replace(/[^a-zA-Z0-9_-]/g, '_')}.json`
          document.body.appendChild(a)
          a.click()
          document.body.removeChild(a)
          URL.revokeObjectURL(url)
        } catch {
          await (window as any).__fmAlert(t('printers.importFailed'))
        }
      })

      // Import params file input
      document.getElementById('import-params-file')?.addEventListener('change', async (e) => {
        const input = e.target as HTMLInputElement
        const file = input.files?.[0]
        if (!file) return
        try {
          const text = await file.text()
          const data = JSON.parse(text)
          const response = await fetch(`/api/v1/printers/${id}/params/import`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify(data),
          })
          if (!response.ok) throw new Error('Failed')
          const result = await response.json()
          await (window as any).__fmAlert(t('printers.importSuccess').replace('{count}', String(result.imported || 0)))
        } catch {
          await (window as any).__fmAlert(t('printers.importFailed'))
        }
        input.value = ''
      })

      // Auto-scroll debug log
      const debugContainer = document.getElementById('debug-log-container')
      if (debugContainer) {
        debugContainer.scrollTop = debugContainer.scrollHeight
      }
    }

    function bindConfigForm() {
      document.getElementById('btn-cancel-config')?.addEventListener('click', () => {
        editingConfig = false
        document.getElementById('config-content')!.innerHTML = renderConfigView()
      })

      document.getElementById('config-form')?.addEventListener('submit', async (e) => {
        e.preventDefault()
        const form = e.target as HTMLFormElement
        const driver_config: Record<string, any> = {}
        const props = pluginSchema.properties as Record<string, any>

        for (const [key, prop] of Object.entries(props)) {
          const el = form.elements.namedItem(key) as HTMLInputElement
          if (!el) continue
          if ((prop as any).type === 'integer' || (prop as any).type === 'number') {
            driver_config[key] = el.value ? Number(el.value) : null
          } else {
            driver_config[key] = el.value || null
          }
        }

        try {
          const response = await fetch(`/api/v1/printers/${id}`, {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': getCsrfToken(),
            },
            credentials: 'include',
            signal: getAbortSignal(),
            body: JSON.stringify({ driver_config }),
          })

          if (response.ok) {
            editingConfig = false
            await loadPrinter()
            // Show inline success message after re-render
            const configContent = document.getElementById('config-content')
            if (configContent) {
              const msg = document.createElement('span')
              msg.textContent = t('printers.configSaved')
              msg.style.cssText = 'font-size: 0.85rem; color: var(--success-text);'
              configContent.prepend(msg)
              setTimeout(() => msg.remove(), 3000)
            }
          } else {
            showConfigMessage(t('printers.failedUpdate'), true)
          }
        } catch {
          showConfigMessage(t('printers.failedUpdate'), true)
        }
      })
    }

    async function loadDriverHealth() {
      try {
        const response = await fetch(`/api/v1/printers/${id}/driver/health`, { credentials: 'include', signal: getAbortSignal() })
        if (response.ok) {
          driverHealth = await response.json()
        }
      } catch {
        driverHealth = null
      }
    }

    function startHealthPolling() {
      if (healthPollTimer) clearInterval(healthPollTimer)
      healthPollTimer = window.setInterval(async () => {
        const prevConnected = driverHealth?.connected
        await loadDriverHealth()
        if (driverHealth?.connected !== prevConnected) {
          // Connection state changed — full re-render to show/hide summary + AMS
          renderPrinter()
        }
      }, 5000)
    }

    function startDebugPolling() {
      stopDebugPolling()
      async function poll() {
        try {
          const url = lastDebugTs
            ? `/api/v1/printers/${id}/driver/debug?since=${encodeURIComponent(lastDebugTs)}`
            : `/api/v1/printers/${id}/driver/debug`
          const response = await fetch(url, { credentials: 'include', signal: getAbortSignal() })
          if (response.ok) {
            const entries: any[] = await response.json()
            if (entries.length > 0) {
              debugLog = debugLog.concat(entries)
              // Keep only last 500
              if (debugLog.length > 500) debugLog = debugLog.slice(-500)
              lastDebugTs = entries[entries.length - 1].ts
              // Update only the debug container
              const container = document.getElementById('debug-log-container')
              if (container) {
                const newHtml = entries.map(entry => {
                  const dirLabel = entry.dir === 'in' ? t('printers.incoming') : t('printers.outgoing')
                  const dirColor = entry.dir === 'in' ? 'var(--accent-2)' : 'var(--accent)'
                  const payloadStr = typeof entry.payload === 'object' ? JSON.stringify(entry.payload, null, 2) : String(entry.payload)
                  return `<div style="border-bottom: 1px solid var(--border); padding: 6px 8px; font-size: 0.8rem;">
                    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 4px;">
                      <span style="color: ${dirColor}; font-weight: 700; font-size: 0.7rem; padding: 1px 6px; border-radius: 4px; background: var(--bg-soft);">${dirLabel}</span>
                      <span style="color: var(--text-muted); font-size: 0.7rem;">${escapeHtml(entry.ts)}</span>
                      <span style="color: var(--text-muted); font-size: 0.7rem; flex: 1;">${escapeHtml(entry.topic)}</span>
                      <button class="btn-copy-debug" style="background:none;border:1px solid var(--border);border-radius:4px;color:var(--text-muted);cursor:pointer;font-size:0.75rem;padding:2px 6px;line-height:1;flex-shrink:0;" title="Copy">&#x29C9;</button>
                    </div>
                    <pre style="margin: 0; white-space: pre-wrap; word-break: break-all; font-size: 0.75rem; color: var(--text); max-height: 200px; overflow-y: auto;">${escapeHtml(payloadStr)}</pre>
                  </div>`
                }).join('')
                container.insertAdjacentHTML('beforeend', newHtml)
                container.scrollTop = container.scrollHeight
              }
            }
          }
        } catch { /* ignore polling errors */ }
      }
      poll()  // immediate first poll
      debugPollTimer = window.setInterval(poll, 2000)
    }

    function stopDebugPolling() {
      if (debugPollTimer) {
        clearInterval(debugPollTimer)
        debugPollTimer = null
      }
    }

    // Stop polling timers on navigation to prevent Chrome connection blocking
    window.addEventListener('pagehide', () => {
      if (healthPollTimer) { clearInterval(healthPollTimer); healthPollTimer = null }
      if (debugPollTimer) { clearInterval(debugPollTimer); debugPollTimer = null }
    })

    // --- SSE Auto-Update (via shared Layout.astro connection) ---
    window.addEventListener('filaman:data-changed', async (e: Event) => {
      const data = (e as CustomEvent).detail
      if (data.printer_id !== undefined && String(data.printer_id) !== String(id)) return
      if (data.event === 'slots_update') {
        await loadDriverHealth()
        renderPrinter()
      } else if (data.event === 'printer_update') {
        await loadPrinter()
      }
    })

    loadPrinter()
  </script>
</Layout>
