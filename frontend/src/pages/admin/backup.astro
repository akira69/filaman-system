---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - Database Backup">
  <div style="margin-bottom: 24px;">
    <a href="/admin" style="color: var(--accent); text-decoration: none;">&larr; <span data-i18n="admin.backToAdmin">Back to Admin</span></a>
  </div>
  
  <h1 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 24px; font-family: var(--font-serif);" data-i18n="admin.databaseBackup">Database Backup & Restore</h1>
  
  <!-- Export Section -->
  <div class="fm-card" style="padding: 24px; margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.backupExport">Export Backup</h2>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.backupExportDesc">
      Create a complete backup of all data (users, spools, filaments, settings, etc.) as JSON file.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">⚠️</span>
      <div style="font-size: 0.875rem; color: var(--warning-text);">
        <strong data-i18n="admin.backupWarningTitle">Warning:</strong>
        <span data-i18n="admin.backupWarningText">This file contains sensitive data (passwords, API keys). Store it securely!</span>
      </div>
    </div>
    <button id="btn-export-backup" class="fm-btn fm-btn-primary" data-i18n="admin.backupExportBtn">
      Export Backup
    </button>
  </div>

  <!-- Import Section -->
  <div class="fm-card" style="padding: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.backupImport">Import Backup</h2>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.backupImportDesc">
      Restore a previously exported backup. This will replace all existing data.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--error-bg); border: 1px solid var(--error-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">🚨</span>
      <div style="font-size: 0.875rem; color: var(--error-text);">
        <strong data-i18n="admin.backupDangerTitle">Danger:</strong>
        <span data-i18n="admin.backupDangerText">This will DELETE ALL existing data! An automatic backup will be created first.</span>
      </div>
    </div>
    <div style="display: flex; gap: 12px; align-items: end; margin-bottom: 16px;">
      <div style="flex: 1;">
        <label style="display: block; margin-bottom: 4px; font-weight: 500; font-size: 0.875rem;">
          <span data-i18n="admin.backupImportFile">Select Backup File</span>
        </label>
        <input 
          type="file" 
          id="backup-file-input" 
          accept=".json"
          style="display: block; width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);"
        />
      </div>
      <button id="btn-import-backup" class="fm-btn fm-btn-danger" disabled data-i18n="admin.backupImportBtn">
        Import Backup
      </button>
    </div>
    <div id="import-progress" style="display: none;">
      <div style="background: var(--bg-soft); height: 6px; border-radius: 999px; overflow: hidden;">
        <div id="import-progress-bar" style="width: 0%; height: 100%; background: var(--accent); transition: width 0.3s;"></div>
      </div>
      <p id="import-status" style="margin-top: 8px; font-size: 0.875rem; color: var(--text-muted);"></p>
    </div>
  </div>

  <!-- Inventory Backup Section -->
  <h2 style="font-size: 1.5rem; font-weight: 700; margin: 48px 0 16px; font-family: var(--font-serif);" data-i18n="admin.inventoryBackup">Inventory Data Only</h2>
  
  <!-- Inventory Export Section -->
  <div class="fm-card" style="padding: 24px; margin-bottom: 24px;">
    <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.inventoryExport">Export Inventory</h3>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.inventoryExportDesc">
      Export only inventory data (manufacturers, filaments, spools, printers). No users, passwords, or API keys.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--success-bg); border: 1px solid var(--success-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">✓</span>
      <div style="font-size: 0.875rem; color: var(--success-text);">
        <strong data-i18n="admin.inventorySafeTitle">Safe to share:</strong>
        <span data-i18n="admin.inventorySafeText">Contains no sensitive authentication data.</span>
      </div>
    </div>
    <button id="btn-export-inventory" class="fm-btn fm-btn-primary" data-i18n="admin.inventoryExportBtn">
      Export Inventory
    </button>
  </div>

  <!-- Inventory Import Section -->
  <div class="fm-card" style="padding: 24px;">
    <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.inventoryImport">Import Inventory</h3>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.inventoryImportDesc">
      Import inventory data from another FilaMan instance. Users and settings are preserved.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">⚠️</span>
      <div style="font-size: 0.875rem; color: var(--warning-text);">
        <strong data-i18n="admin.inventoryWarningTitle">Warning:</strong>
        <span data-i18n="admin.inventoryWarningText">This will DELETE existing inventory data! Users and settings remain unchanged.</span>
      </div>
    </div>
    <div style="display: flex; gap: 12px; align-items: end; margin-bottom: 16px;">
      <div style="flex: 1;">
        <label style="display: block; margin-bottom: 4px; font-weight: 500; font-size: 0.875rem;">
          <span data-i18n="admin.backupImportFile">Select Backup File</span>
        </label>
        <input 
          type="file" 
          id="inventory-file-input" 
          accept=".json"
          style="display: block; width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);"
        />
      </div>
      <button id="btn-import-inventory" class="fm-btn fm-btn-warning" disabled data-i18n="admin.inventoryImportBtn">
        Import Inventory
      </button>
    </div>
    <div id="inventory-import-progress" style="display: none;">
      <div style="background: var(--bg-soft); height: 6px; border-radius: 999px; overflow: hidden;">
        <div id="inventory-import-progress-bar" style="width: 0%; height: 100%; background: var(--accent); transition: width 0.3s;"></div>
      </div>
      <p id="inventory-import-status" style="margin-top: 8px; font-size: 0.875rem; color: var(--text-muted);"></p>
    </div>
  </div>

  <!-- SQLite Backup Files Section -->
  <div id="sqlite-backups-section" class="fm-card" style="padding: 24px; margin-top: 24px; display: none;">
    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.sqliteBackups">SQLite Backups</h2>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.sqliteBackupsDesc">
      Automatic SQLite database backups. These are created daily and before updates.
    </p>
    <div id="sqlite-backups-loading" style="text-align: center; padding: 24px; color: var(--text-muted);" data-i18n="common.loading">Loading...</div>
    <div id="sqlite-backups-empty" style="display: none; text-align: center; padding: 24px; color: var(--text-muted);" data-i18n="admin.sqliteBackupsEmpty">No backup files found.</div>
    <div id="sqlite-backups-table-wrap" style="display: none; overflow-x: auto;">
      <table class="fm-table">
        <thead style="background: var(--bg-soft);">
          <tr>
            <th data-i18n="admin.sqliteBackupFile">File</th>
            <th data-i18n="admin.sqliteBackupDate">Date</th>
            <th data-i18n="admin.sqliteBackupSize">Size</th>
            <th style="text-align: right;" data-i18n="common.actions">Actions</th>
          </tr>
        </thead>
        <tbody id="sqlite-backups-tbody"></tbody>
      </table>
    </div>
  </div>

  <script>
    import { initI18n, t } from '../../lib/i18n'
    import { getAbortSignal, isAbortError } from '../../lib/abort'
    initI18n()

    function getCsrfToken(): string {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    const btnExportBackup = document.getElementById('btn-export-backup') as HTMLButtonElement
    const btnImportBackup = document.getElementById('btn-import-backup') as HTMLButtonElement
    const backupFileInput = document.getElementById('backup-file-input') as HTMLInputElement
    const importProgress = document.getElementById('import-progress')!
    const importProgressBar = document.getElementById('import-progress-bar') as HTMLElement
    const importStatus = document.getElementById('import-status')!

    backupFileInput.addEventListener('change', () => {
      btnImportBackup.disabled = !backupFileInput.files || backupFileInput.files.length === 0
    })

    btnExportBackup.addEventListener('click', async () => {
      btnExportBackup.disabled = true
      const originalText = btnExportBackup.textContent
      btnExportBackup.textContent = t('admin.backupExporting') || 'Exporting...'

      try {
        const response = await fetch('/api/v1/admin/system/backup/export', {
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          signal: getAbortSignal(),
        })

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Export failed' } }))
          throw new Error(errorData.detail?.message || 'Export failed')
        }

        const blob = await response.blob()
        const contentDisposition = response.headers.get('Content-Disposition')
        let filename = 'filaman_backup.json'
        if (contentDisposition) {
          const match = contentDisposition.match(/filename="(.+)"/)
          if (match) filename = match[1]
        }

        const url = window.URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = filename
        document.body.appendChild(a)
        a.click()
        window.URL.revokeObjectURL(url)
        document.body.removeChild(a)

        await (window as any).__fmSuccess(t('admin.backupExportSuccess') || 'Backup exported successfully')
      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Export failed:', err)
        await (window as any).__fmAlert(t('admin.backupExportFailed') || `Export failed: ${err.message}`)
      } finally {
        btnExportBackup.disabled = false
        btnExportBackup.textContent = originalText
      }
    })

    btnImportBackup.addEventListener('click', async () => {
      const file = backupFileInput.files?.[0]
      if (!file) return

      const confirmMsg = t('admin.backupImportConfirm') || 
        'Are you sure you want to import this backup?\n\nThis will DELETE ALL existing data!\n\nAn automatic backup will be created first.'
      
      const confirmed = await (window as any).__fmConfirm(confirmMsg)
      if (!confirmed) return

      btnImportBackup.disabled = true
      const originalText = btnImportBackup.textContent
      btnImportBackup.textContent = t('admin.backupImporting') || 'Importing...'
      
      importProgress.style.display = 'block'
      importProgressBar.style.width = '10%'
      importStatus.textContent = t('admin.backupImportPreparing') || 'Preparing import...'

      try {
        const formData = new FormData()
        formData.append('file', file)

        importProgressBar.style.width = '30%'
        importStatus.textContent = t('admin.backupImportUploading') || 'Uploading backup file...'

        const response = await fetch('/api/v1/admin/system/backup/import', {
          method: 'POST',
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          body: formData,
          signal: getAbortSignal(),
        })

        importProgressBar.style.width = '90%'
        importStatus.textContent = t('admin.backupImportProcessing') || 'Processing import...'

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Import failed' } }))
          throw new Error(errorData.detail?.message || 'Import failed')
        }

        const result = await response.json()

        importProgressBar.style.width = '100%'
        importStatus.textContent = t('admin.backupImportComplete') || 'Import complete!'

        await (window as any).__fmSuccess(
          (t('admin.backupImportSuccess') || 'Backup imported successfully!') + '\n\n' + result.message
        )

        backupFileInput.value = ''
        btnImportBackup.disabled = true

        setTimeout(() => {
          window.location.reload()
        }, 2000)

      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Import failed:', err)
        importStatus.textContent = ''
        await (window as any).__fmAlert(
          (t('admin.backupImportFailed') || 'Import failed:') + '\n\n' + err.message
        )
      } finally {
        setTimeout(() => {
          importProgress.style.display = 'none'
          importProgressBar.style.width = '0%'
          importStatus.textContent = ''
          btnImportBackup.disabled = !backupFileInput.files || backupFileInput.files.length === 0
          btnImportBackup.textContent = originalText
        }, 3000)
      }
    })

    // --- Inventory Backup Export/Import ---
    const btnExportInventory = document.getElementById('btn-export-inventory') as HTMLButtonElement
    const btnImportInventory = document.getElementById('btn-import-inventory') as HTMLButtonElement
    const inventoryFileInput = document.getElementById('inventory-file-input') as HTMLInputElement
    const inventoryImportProgress = document.getElementById('inventory-import-progress')!
    const inventoryImportProgressBar = document.getElementById('inventory-import-progress-bar') as HTMLElement
    const inventoryImportStatus = document.getElementById('inventory-import-status')!

    inventoryFileInput.addEventListener('change', () => {
      btnImportInventory.disabled = !inventoryFileInput.files || inventoryFileInput.files.length === 0
    })

    btnExportInventory.addEventListener('click', async () => {
      btnExportInventory.disabled = true
      const originalText = btnExportInventory.textContent
      btnExportInventory.textContent = t('admin.inventoryExporting') || 'Exporting...'

      try {
        const response = await fetch('/api/v1/admin/system/backup/export-inventory', {
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          signal: getAbortSignal(),
        })

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Export failed' } }))
          throw new Error(errorData.detail?.message || 'Export failed')
        }

        const blob = await response.blob()
        const contentDisposition = response.headers.get('Content-Disposition')
        let filename = 'filaman_inventory.json'
        if (contentDisposition) {
          const match = contentDisposition.match(/filename="(.+)"/)
          if (match) filename = match[1]
        }

        const url = window.URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = filename
        document.body.appendChild(a)
        a.click()
        window.URL.revokeObjectURL(url)
        document.body.removeChild(a)

        await (window as any).__fmSuccess(t('admin.inventoryExportSuccess') || 'Inventory exported successfully')
      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Inventory export failed:', err)
        await (window as any).__fmAlert(t('admin.inventoryExportFailed') || `Export failed: ${err.message}`)
      } finally {
        btnExportInventory.disabled = false
        btnExportInventory.textContent = originalText
      }
    })

    btnImportInventory.addEventListener('click', async () => {
      const file = inventoryFileInput.files?.[0]
      if (!file) return

      const confirmMsg = t('admin.inventoryImportConfirm') || 
        'Are you sure you want to import this inventory?\n\nThis will DELETE ALL existing inventory data!\n\nUsers and settings will be preserved.\n\nAn automatic backup will be created first.'
      
      const confirmed = await (window as any).__fmConfirm(confirmMsg)
      if (!confirmed) return

      btnImportInventory.disabled = true
      const originalText = btnImportInventory.textContent
      btnImportInventory.textContent = t('admin.inventoryImporting') || 'Importing...'
      
      inventoryImportProgress.style.display = 'block'
      inventoryImportProgressBar.style.width = '10%'
      inventoryImportStatus.textContent = t('admin.inventoryImportPreparing') || 'Preparing import...'

      try {
        const formData = new FormData()
        formData.append('file', file)

        inventoryImportProgressBar.style.width = '30%'
        inventoryImportStatus.textContent = t('admin.inventoryImportUploading') || 'Uploading inventory file...'

        const response = await fetch('/api/v1/admin/system/backup/import-inventory', {
          method: 'POST',
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          body: formData,
          signal: getAbortSignal(),
        })

        inventoryImportProgressBar.style.width = '90%'
        inventoryImportStatus.textContent = t('admin.inventoryImportProcessing') || 'Processing import...'

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Import failed' } }))
          throw new Error(errorData.detail?.message || 'Import failed')
        }

        const result = await response.json()

        inventoryImportProgressBar.style.width = '100%'
        inventoryImportStatus.textContent = t('admin.inventoryImportComplete') || 'Import complete!'

        await (window as any).__fmSuccess(
          (t('admin.inventoryImportSuccess') || 'Inventory imported successfully!') + '\n\n' + result.message
        )

        inventoryFileInput.value = ''
        btnImportInventory.disabled = true

        setTimeout(() => {
          window.location.reload()
        }, 2000)

      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Inventory import failed:', err)
        inventoryImportStatus.textContent = ''
        await (window as any).__fmAlert(
          (t('admin.inventoryImportFailed') || 'Import failed:') + '\n\n' + err.message
        )
      } finally {
        setTimeout(() => {
          inventoryImportProgress.style.display = 'none'
          inventoryImportProgressBar.style.width = '0%'
          inventoryImportStatus.textContent = ''
          btnImportInventory.disabled = !inventoryFileInput.files || inventoryFileInput.files.length === 0
          btnImportInventory.textContent = originalText
        }, 3000)
      }
    })

    // --- SQLite Backups ---
    const sqliteSection = document.getElementById('sqlite-backups-section')!
    const sqliteLoading = document.getElementById('sqlite-backups-loading')!
    const sqliteEmpty = document.getElementById('sqlite-backups-empty')!
    const sqliteTableWrap = document.getElementById('sqlite-backups-table-wrap')!
    const sqliteTbody = document.getElementById('sqlite-backups-tbody')!

    function formatBytes(bytes: number): string {
      if (bytes < 1024) return `${bytes} B`
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
      return `${(bytes / (1024 * 1024)).toFixed(1)} MB`
    }

    function formatDate(iso: string): string {
      const d = new Date(iso)
      return d.toLocaleString(undefined, {
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit'
      })
    }

    async function loadSqliteBackups() {
      try {
        const resp = await fetch('/api/v1/admin/system/backup/sqlite-list', {
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          signal: getAbortSignal(),
        })
        if (!resp.ok) return

        const data = await resp.json()
        if (!data.is_sqlite) return

        sqliteSection.style.display = 'block'
        sqliteLoading.style.display = 'none'

        if (!data.backups || data.backups.length === 0) {
          sqliteEmpty.style.display = 'block'
          return
        }

        sqliteTableWrap.style.display = 'block'
        sqliteTbody.innerHTML = ''

        for (const backup of data.backups) {
          const tr = document.createElement('tr')
          tr.innerHTML = `
            <td style="font-family: monospace; font-size: 0.85rem;">${backup.filename}</td>
            <td>${formatDate(backup.created_at)}</td>
            <td>${formatBytes(backup.size_bytes)}</td>
            <td style="text-align: right; white-space: nowrap;">
              <button class="fm-btn fm-btn-sm fm-btn-outline btn-sqlite-restore" data-filename="${backup.filename}"
                data-i18n="admin.sqliteRestore">Restore</button>
              <button class="fm-btn fm-btn-sm fm-btn-danger btn-sqlite-delete" data-filename="${backup.filename}"
                style="margin-left: 6px;" data-i18n="common.delete">Delete</button>
            </td>
          `
          sqliteTbody.appendChild(tr)
        }

        sqliteTbody.querySelectorAll('.btn-sqlite-restore').forEach(btn => {
          btn.addEventListener('click', (e) => restoreSqliteBackup((e.currentTarget as HTMLElement).dataset.filename!))
        })
        sqliteTbody.querySelectorAll('.btn-sqlite-delete').forEach(btn => {
          btn.addEventListener('click', (e) => deleteSqliteBackup((e.currentTarget as HTMLElement).dataset.filename!))
        })

      } catch (err) {
        if (isAbortError(err)) return
        console.error('Failed to load SQLite backups:', err)
      }
    }

    async function restoreSqliteBackup(filename: string) {
      const confirmMsg = (t('admin.sqliteRestoreConfirm') || 
        'Are you sure you want to restore the backup "{filename}"?\n\nThe current database will be replaced. An automatic backup will be created first.')
        .replace('{filename}', filename)

      const confirmed = await (window as any).__fmConfirm(confirmMsg)
      if (!confirmed) return

      try {
        const resp = await fetch('/api/v1/admin/system/backup/sqlite-restore', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken()
          },
          body: JSON.stringify({ filename }),
          signal: getAbortSignal(),
        })

        if (!resp.ok) {
          const err = await resp.json().catch(() => ({ detail: { message: 'Restore failed' } }))
          throw new Error(err.detail?.message || 'Restore failed')
        }

        const result = await resp.json()
        await (window as any).__fmSuccess(
          (t('admin.sqliteRestoreSuccess') || 'Database restored successfully!') +
          '\n\n' + result.message
        )

        setTimeout(() => window.location.reload(), 2000)

      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Restore failed:', err)
        await (window as any).__fmAlert(
          (t('admin.sqliteRestoreFailed') || 'Restore failed:') + '\n\n' + err.message
        )
      }
    }

    async function deleteSqliteBackup(filename: string) {
      const confirmMsg = (t('admin.sqliteDeleteConfirm') || 
        'Are you sure you want to delete the backup "{filename}"?')
        .replace('{filename}', filename)

      const confirmed = await (window as any).__fmConfirm(confirmMsg)
      if (!confirmed) return

      try {
        const resp = await fetch(`/api/v1/admin/system/backup/sqlite/${encodeURIComponent(filename)}`, {
          method: 'DELETE',
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          signal: getAbortSignal(),
        })

        if (!resp.ok) {
          const err = await resp.json().catch(() => ({ detail: { message: 'Delete failed' } }))
          throw new Error(err.detail?.message || 'Delete failed')
        }

        await loadSqliteBackups()

      } catch (err: any) {
        if (isAbortError(err)) return
        console.error('Delete failed:', err)
        await (window as any).__fmAlert(
          (t('admin.sqliteDeleteFailed') || 'Delete failed:') + '\n\n' + err.message
        )
      }
    }

    loadSqliteBackups()
  </script>
</Layout>
