---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - Admin">
  <h1 style="font-size: 1.8rem; font-weight: 700; margin: 0; margin-bottom: 24px; font-family: var(--font-serif);" data-i18n="admin.title">Admin</h1>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
    <a href="/admin/users" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.users">Users</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.usersDesc">Manage user accounts</p>
    </a>
    <a href="/admin/roles" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.rolesPerms">Roles & Permissions</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.rolesPermsDesc">Manage roles and permissions</p>
    </a>
    <a href="/admin/devices" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.devices">Devices</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.devicesDesc">Manage device tokens</p>
    </a>
    <a href="/admin/extra-fields" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.extraFieldsTitle">Extra Fields</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.extraFieldsDesc">System-wide extra fields for spools and filaments</p>
    </a>
    <a href="/admin/system" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.system">System</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.systemDesc">Plugins and system management</p>
    </a>
    <a href="/admin/backup" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.databaseBackup">Database Backup</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.backupDesc">Export and restore complete database backups</p>
    </a>
    <a href="/admin/oidc" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;" id="oidc-card">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.oidc">OIDC / SSO</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.oidcDesc">Configure OpenID Connect Single Sign-On</p>
      <span id="oidc-https-warning" style="display: none; font-size: 0.8rem; color: var(--error-text); margin-top: 8px; display: none;" data-i18n="admin.oidcHttpsRequired">OIDC requires HTTPS</span>
    </a>
    <a href="/admin/app-settings" class="fm-card fm-card-hover" style="padding: 24px; text-decoration: none; display: block; color: inherit;">
      <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.appSettings">App Settings</h2>
      <p style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.appSettingsDesc">Application-wide settings like login and authentication</p>
    </a>
  </div>

  <h2 style="font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; font-family: var(--font-serif);" data-i18n="admin.versionInfoTitle">System Version</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px;">
    <div class="fm-card" style="padding: 24px;">
      <div style="display: grid; gap: 8px;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <span style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.installedVersion">Installed:</span>
          <span id="installed-version" style="font-weight: 600;">...</span>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <span style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.latestVersion">Latest:</span>
          <span id="latest-version" style="font-weight: 600;">...</span>
        </div>
        <div id="plugin-updates-row" class="invisible" style="display: flex; align-items: center; gap: 12px;">
          <span style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.pluginUpdates">Plugin Updates:</span>
          <span id="plugin-update-count" style="font-weight: 600;"></span>
        </div>
        <a href="/admin/system/changelog" class="fm-btn fm-btn-outline" style="margin-top: 8px; text-align: center;" data-i18n="admin.viewChangelog">Changelog</a>
      </div>
    </div>
    <div class="fm-card" style="padding: 24px;">
      <div style="display: grid; gap: 8px;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <span style="font-size: 0.85rem; color: var(--text-muted);" data-i18n="admin.apiVersion">API Version:</span>
          <span id="api-version" style="font-weight: 600;">...</span>
        </div>
        <a href="/admin/api-docs" class="fm-btn fm-btn-outline" style="margin-top: 8px; text-align: center;" data-i18n="admin.openApiDocs">API Documentation</a>
      </div>
    </div>
  </div>

  <h2 style="font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; color: var(--error-text); font-family: var(--font-serif);" data-i18n="admin.dangerZone">Danger Zone</h2>
  <div class="fm-card" style="border: 1px solid var(--error-text); padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap;">
      <div>
        <h3 style="font-size: 1.05rem; font-weight: 600; margin: 0 0 4px;" data-i18n="admin.killswitchTitle">Delete all data</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;" data-i18n="admin.killswitchDesc">Permanently delete all spools, filaments, manufacturers, colors, locations, and printers including their logs and events. Users, roles, permissions, and devices are not affected.</p>
      </div>
      <button
        id="btn-killswitch"
        class="fm-btn"
        style="background: var(--error-text); color: #fff; white-space: nowrap; flex-shrink: 0;"
        data-i18n="admin.killswitchButton"
      >
        Delete all data
      </button>
    </div>
  </div>

  <script>
    import { t, initI18n } from '../../lib/i18n'
    import { getAbortSignal, isAbortError } from '../../lib/abort'
    await initI18n()

    function getCsrfToken(): string {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    document.getElementById('btn-killswitch')?.addEventListener('click', async () => {
      const msg1 = t('admin.killswitchConfirm')
      if (!(await (window as any).__fmConfirm(msg1))) return

      const msg2 = t('admin.killswitchConfirm2')
      if (!(await (window as any).__fmConfirm(msg2))) return

      const btn = document.getElementById('btn-killswitch') as HTMLButtonElement
      btn.disabled = true
      btn.textContent = t('admin.killswitchExecuting')

      try {
        const csrfToken = getCsrfToken()
        if (!csrfToken) {
          throw new Error(t('admin.sessionExpired') || 'Session expired – please log in again.')
        }

        const response = await fetch('/api/v1/admin/system/killswitch', {
          method: 'DELETE',
          headers: { 'X-CSRF-Token': csrfToken },
          credentials: 'include',
          signal: getAbortSignal(),
        })

        if (!response.ok) {
          const data = await response.json().catch(() => ({}))
          if (response.status === 403 && data.code === 'csrf_failed') {
            throw new Error(t('admin.sessionExpired') || 'Session expired – please log in again.')
          }
          const msg = data.detail?.message || data.message || data.detail || `HTTP ${response.status}`
          throw new Error(msg)
        }

        const result = await response.json()
        const total = Object.values(result.deleted as Record<string, number>).reduce((a: number, b: number) => a + b, 0)
        const details = Object.entries(result.deleted as Record<string, number>)
          .filter(([_, count]) => count > 0)
          .map(([table, count]) => `${table}: ${count}`)
          .join('\n')

        await (window as any).__fmAlert(
          t('admin.killswitchSuccess').replace('{count}', String(total))
          + (details ? '\n\n' + details : '')
        )

      } catch (err: any) {
        if (isAbortError(err)) return
        await (window as any).__fmAlert(err.message || t('admin.killswitchFailed'))
      } finally {
        btn.disabled = false
        btn.textContent = t('admin.killswitchButton')
      }
    })

    /* ── Version check ───────────────────────────────────────── */
    ;(async function loadVersionInfo() {
      try {
        const resp = await fetch('/api/v1/admin/system/version-check', { credentials: 'include', signal: getAbortSignal() })
        if (!resp.ok) return
        const data = await resp.json()

        const installedEl = document.getElementById('installed-version')!
        const latestEl = document.getElementById('latest-version')!
        const pluginRow = document.getElementById('plugin-updates-row')!
        const pluginCount = document.getElementById('plugin-update-count')!
        installedEl.textContent = `v${data.installed_version}`
        latestEl.textContent = data.latest_version ? `v${data.latest_version}` : t('admin.versionUnknown')

        /* API Version card */
        const apiVersionEl = document.getElementById('api-version')
        if (apiVersionEl) apiVersionEl.textContent = `v${data.installed_version}`

        if (data.update_available) {
          latestEl.style.color = 'var(--error-text)'
        } else {
          latestEl.style.color = 'var(--success-text)'
        }

        const updatablePlugins = (data.latest_plugins || []).filter((p: any) => p.update_available)
        if (updatablePlugins.length > 0) {
          pluginRow.classList.remove('invisible')
          pluginCount.textContent = String(updatablePlugins.length)
        }
      } catch {
        // Silently fail — card just shows loading dots
      }
    })()

    /* ── OIDC card HTTPS check ────────────────────────────── */
    ;(function checkOidcHttps() {
      const card = document.getElementById('oidc-card')
      const warning = document.getElementById('oidc-https-warning')
      if (!card || !warning) return
      if (window.location.protocol !== 'https:') {
        card.setAttribute('href', 'javascript:void(0)')
        card.classList.remove('fm-card-hover')
        card.style.opacity = '0.6'
        card.style.cursor = 'not-allowed'
        warning.style.display = 'block'
      }
    })()
  </script>
</Layout>
